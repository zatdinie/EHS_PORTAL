    <script>
        // Add some basic form validation and user experience enhancements
        document.addEventListener('DOMContentLoaded', function() {
            // Auto-expand sections on focus
            const tables = document.querySelectorAll('.inspection-table');
            tables.forEach(table => {
                table.addEventListener('focusin', function() {
                    this.closest('.category-section').style.boxShadow = '0 4px 20px rgba(0,122,204,0.2)';
                });
                table.addEventListener('focusout', function() {
                    this.closest('.category-section').style.boxShadow = 'none';
                });
            });

            // Form submission confirmation
            const form = document.querySelector('form');
            form.addEventListener('submit', function(e) {
                const confirmation = confirm('Are you sure you want to submit this EHS Inspection Report? Please ensure all required fields are completed.');
                if (!confirmation) {
                    e.preventDefault();
                }
            });

            // Highlight non-compliance selections
            const radioInputs = document.querySelectorAll('input[type="radio"][value="X"]');
            radioInputs.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.checked) {
                        this.closest('td').style.backgroundColor = '#ffebee';
                    }
                });
            });

            // Reset background color for compliance selections
            const complianceRadios = document.querySelectorAll('input[type="radio"][value="P"], input[type="radio"][value="N/A"]');
            complianceRadios.forEach(radio => {
                radio.addEventListener('change', function() {
                    if (this.checked) {
                        this.closest('td').style.backgroundColor = '';
                    }
                });
            });
        });
    </script>
