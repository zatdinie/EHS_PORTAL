@model IEnumerable<EHS_PORTAL.Areas.CLIP.Models.ActivityLog>
@{
    ViewBag.Title = "User Activity";
}

<h2>User Activity: @ViewBag.UserName</h2>

<div class="panel panel-default">
    <div class="panel-heading">
        <h3 class="panel-title">Activity History</h3>
    </div>
    <div class="panel-body">
        @if (!Model.Any())
        {
            <div class="alert alert-info">
                No activity logs found for this user.
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-striped table-bordered table-hover">
                    <thead>
                        <tr>
                            <th>Date/Time</th>
                            <th>Action</th>
                            <th>Description</th>
                            <th>Entity</th>
                            <th>IP Address</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in Model)
                        {
                            <tr>
                                <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                                <td>
                                    <span class="label @GetActionLabelClass(log.Action)">@log.Action</span>
                                </td>
                                <td>@log.Description</td>
                                <td>
                                    @if (!string.IsNullOrEmpty(log.EntityName))
                                    {
                                        <span>@log.EntityName</span>
                                        @if (!string.IsNullOrEmpty(log.EntityID))
                                        {
                                            <span class="text-muted"> (#@log.EntityID)</span>
                                        }
                                    }
                                </td>
                                <td>@log.IPAddress</td>
                                <td>
                                    <a href="@Url.Action("Details", new { id = log.LogID })" class="btn btn-xs btn-info">
                                        <i class="fa fa-search"></i> Details
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
    <div class="panel-footer">
        <a href="@Url.Action("Index")" class="btn btn-default">
            <i class="fa fa-arrow-left"></i> Back to List
        </a>
    </div>
</div>

@functions {
    public string GetActionLabelClass(string action)
    {
        switch (action?.ToUpper())
        {
            case "LOGIN":
            case "LOGOUT":
                return "label-default";
            case "CREATE":
                return "label-success";
            case "UPDATE":
                return "label-primary";
            case "DELETE":
                return "label-danger";
            case "VIEW":
                return "label-info";
            default:
                return "label-default";
        }
    }
} 