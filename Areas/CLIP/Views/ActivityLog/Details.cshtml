@model EHS_PORTAL.Areas.CLIP.Models.ActivityLog
@{
    ViewBag.Title = "Activity Log Details";
}

<br />
<h1>Activity Log Details</h1>

<div class="card mb-4">
    <div class="card-header bg-light d-flex justify-content-between align-items-center">
        <h5 class="card-title mb-0">
            <i class="bi bi-journal-text"></i> Log Entry #@Model.LogID
        </h5>
        <span class="badge @GetActionBadgeClass(Model.Action)">@Model.Action</span>
    </div>
    <div class="card-body">
        <div class="row">
            <div class="col-md-6">
                <table class="table table-sm">
                    <tbody>
                        <tr>
                            <th style="width: 30%">Date/Time:</th>
                            <td>@Model.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        </tr>
                        <tr>
                            <th>User:</th>
                            <td>@Model.UserName</td>
                        </tr>
                        <tr>
                            <th>Description:</th>
                            <td>@Model.Description</td>
                        </tr>
                        <tr>
                            <th>Entity Type:</th>
                            <td>@Model.EntityName</td>
                        </tr>
                        <tr>
                            <th>Entity ID:</th>
                            <td>@Model.EntityID</td>
                        </tr>
                    </tbody>
                </table>
            </div>
            <div class="col-md-6">
                <table class="table table-sm">
                    <tbody>
                        <tr>
                            <th style="width: 30%">IP Address:</th>
                            <td>@Model.IPAddress</td>
                        </tr>
                        <tr>
                            <th>User Agent:</th>
                            <td>
                                <small class="text-muted">@Model.UserAgent</small>
                            </td>
                        </tr>
                        <tr>
                            <th>Page URL:</th>
                            <td>
                                <small class="text-muted">@Model.PageUrl</small>
                            </td>
                        </tr>
                        <tr>
                            <th>Session ID:</th>
                            <td>
                                <small class="text-muted">@Model.SessionID</small>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Model.OldValue) || !string.IsNullOrEmpty(Model.NewValue))
        {
            <hr />
            <h5 class="mb-3"><i class="bi bi-pencil-square"></i> Changes</h5>
            <div class="row">
                @if (!string.IsNullOrEmpty(Model.OldValue))
                {
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <h6 class="card-title mb-0">Previous Value</h6>
                            </div>
                            <div class="card-body">
                                <pre class="mb-0" style="max-height: 300px; overflow-y: auto;">@Model.OldValue</pre>
                            </div>
                        </div>
                    </div>
                }
                @if (!string.IsNullOrEmpty(Model.NewValue))
                {
                    <div class="col-md-6">
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <h6 class="card-title mb-0">New Value</h6>
                            </div>
                            <div class="card-body">
                                <pre class="mb-0" style="max-height: 300px; overflow-y: auto;">@Model.NewValue</pre>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
    <div class="card-footer">
        <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left"></i> Back to List
        </a>
    </div>
</div>

@functions {
    public string GetActionBadgeClass(string action)
    {
        switch (action?.ToUpper())
        {
            case "LOGIN":
            case "LOGOUT":
                return "bg-secondary";
            case "CREATE":
                return "bg-success";
            case "UPDATE":
                return "bg-primary";
            case "DELETE":
                return "bg-danger";
            case "VIEW":
                return "bg-info";
            default:
                return "bg-secondary";
        }
    }
} 