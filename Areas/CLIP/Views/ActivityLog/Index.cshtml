@model PagedList.IPagedList<EHS_PORTAL.Areas.CLIP.Models.ActivityLog>
@using PagedList.Mvc;
@{
    ViewBag.Title = "Activity Logs";
    var searchTerm = ViewBag.CurrentSearchTerm as string;
    var filterAction = ViewBag.CurrentFilterAction as string;
    var filterEntity = ViewBag.CurrentFilterEntity as string;
    var startDate = ViewBag.CurrentStartDate;
    var endDate = ViewBag.CurrentEndDate;
}

<style>
    /* Custom styles for PagedList pager */
    .pagination {
        display: flex;
        padding-left: 0;
        list-style: none;
        border-radius: 0.25rem;
    }

    .pagination > li {
        display: inline;
    }

    .pagination > li > a,
    .pagination > li > span {
        position: relative;
        float: left;
        padding: 0.5rem 0.75rem;
        margin-left: -1px;
        line-height: 1.25;
        color: #0d6efd;
        background-color: #fff;
        border: 1px solid #dee2e6;
        text-decoration: none;
    }

    .pagination > li:first-child > a,
    .pagination > li:first-child > span {
        margin-left: 0;
        border-top-left-radius: 0.25rem;
        border-bottom-left-radius: 0.25rem;
    }

    .pagination > li:last-child > a,
    .pagination > li:last-child > span {
        border-top-right-radius: 0.25rem;
        border-bottom-right-radius: 0.25rem;
    }

    .pagination > li > a:hover,
    .pagination > li > span:hover,
    .pagination > li > a:focus,
    .pagination > li > span:focus {
        z-index: 2;
        color: #0a58ca;
        background-color: #e9ecef;
        border-color: #dee2e6;
    }

    .pagination > .active > a,
    .pagination > .active > span,
    .pagination > .active > a:hover,
    .pagination > .active > span:hover,
    .pagination > .active > a:focus,
    .pagination > .active > span:focus {
        z-index: 3;
        color: #fff;
        background-color: #0d6efd;
        border-color: #0d6efd;
        cursor: default;
    }
</style>

<br />
<h1>Activity Logs</h1>

<div class="card mb-4">
    <div class="card-body">
        <h5 class="card-title mb-3"><i class="bi bi-funnel"></i> Filter Options</h5>
        @using (Html.BeginForm("Index", "ActivityLog", FormMethod.Get, new { @class = "row g-3" }))
        {
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Search:</label>
                    <input type="text" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Search by user, description, entity..." />
                </div>
                <div class="mb-3">
                    <label class="form-label">Action Type:</label>
                    <select name="filterAction" class="form-select">
                        <option value="">-- All Actions --</option>
                        @foreach (var action in ViewBag.Actions as List<string>)
                        {
                            <option value="@action" @(action == filterAction ? "selected" : "")>@action</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label class="form-label">Entity Type:</label>
                    <select name="filterEntity" class="form-select">
                        <option value="">-- All Entities --</option>
                        @foreach (var entity in ViewBag.EntityNames as List<string>)
                        {
                            <option value="@entity" @(entity == filterEntity ? "selected" : "")>@entity</option>
                        }
                    </select>
                </div>
            </div>
            <div class="col-md-6">
                <div class="mb-3">
                    <label class="form-label">Start Date:</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                        <input type="text" name="startDate" value="@startDate" class="form-control date-picker" placeholder="From Date" />
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label">End Date:</label>
                    <div class="input-group">
                        <span class="input-group-text"><i class="bi bi-calendar3"></i></span>
                        <input type="text" name="endDate" value="@endDate" class="form-control date-picker" placeholder="To Date" />
                    </div>
                </div>
                <div class="d-flex gap-2 mt-4">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Filter
                    </button>
                    <a href="@Url.Action("Index")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Reset
                    </a>
                </div>
            </div>
        }
    </div>
</div>

<div class="table-responsive">
    <table class="table table-hover" id="activityLogTable">
        <thead class="bg-light">
            <tr>
                <th>Date/Time</th>
                <th>User</th>
                <th>Action</th>
                <th>Description</th>
                <th>Entity</th>
                <th>IP Address</th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count() == 0)
            {
                <tr>
                    <td colspan="7" class="text-center py-4">
                        <i class="bi bi-info-circle text-info fs-4 d-block mb-2"></i>
                        <p class="mb-1">No activity logs found matching your filters.</p>
                        <a href="@Url.Action("Index", "ActivityLog")" class="btn btn-outline-primary btn-sm mt-2">
                            <i class="bi bi-arrow-clockwise"></i> Show All Logs
                        </a>
                    </td>
                </tr>
            }
            else
            {
                foreach (var log in Model)
                {
                    <tr>
                        <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                        <td>@log.UserName</td>
                        <td>
                            @{
                                string badgeClass = GetActionBadgeClass(log.Action);
                            }
                            <span class="badge @badgeClass">@log.Action</span>
                        </td>
                        <td>@log.Description</td>
                        <td>
                            @if (!string.IsNullOrEmpty(log.EntityName))
                            {
                                <span>@log.EntityName</span>
                                if (!string.IsNullOrEmpty(log.EntityID))
                                {
                                    <span class="text-muted"> (#@log.EntityID)</span>
                                }
                            }
                        </td>
                        <td>@log.IPAddress</td>
                        <td class="text-center">
                            <a href="@Url.Action("Details", new { id = log.LogID })" 
                               class="btn btn-info btn-sm" data-bs-toggle="tooltip" title="View Details">
                                <i class="bi bi-info-circle"></i>
                            </a>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

<div class="d-flex justify-content-center mt-4">
    @Html.PagedListPager(Model, page => Url.Action("Index", new {
        page,
        searchTerm = searchTerm,
        filterAction = filterAction,
        filterEntity = filterEntity,
        startDate = startDate,
        endDate = endDate
    }))
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Initialize date pickers
            $('.date-picker').datepicker({
                format: 'yyyy-mm-dd',
                autoclose: true,
                todayHighlight: true
            });

            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();

            // DataTable initialization if it's available
            if ($.fn.DataTable) {
                $('#activityLogTable').DataTable({
                    "paging": false,  // We're using PagedList for paging
                    "ordering": true,
                    "info": false,
                    "searching": false, // We have our own search
                    "responsive": true,
                    "language": {
                        "zeroRecords": "No matching records found"
                    }
                });
            }
        });
    </script>
}

@functions {
    public string GetActionBadgeClass(string action)
    {
        switch (action?.ToUpper())
        {
            case "LOGIN":
            case "LOGOUT":
                return "bg-secondary";
            case "CREATE":
                return "bg-success";
            case "UPDATE":
                return "bg-primary";
            case "DELETE":
                return "bg-danger";
            case "VIEW":
                return "bg-info";
            default:
                return "bg-secondary";
        }
    }
} 