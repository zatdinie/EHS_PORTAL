@model PagedList.IPagedList<EHS_PORTAL.Areas.CLIP.Models.ActivityLog>
@using PagedList.Mvc;
@{
    ViewBag.Title = "Activity Logs";
    var searchTerm = ViewBag.CurrentSearchTerm as string;
    var filterAction = ViewBag.CurrentFilterAction as string;
    var filterEntity = ViewBag.CurrentFilterEntity as string;
    var startDate = ViewBag.CurrentStartDate;
    var endDate = ViewBag.CurrentEndDate;
}

<h2>Activity Logs</h2>

<div class="panel panel-default">
    <div class="panel-heading">
        <h3 class="panel-title">Filter Options</h3>
    </div>
    <div class="panel-body">
        @using (Html.BeginForm("Index", "ActivityLog", FormMethod.Get, new { @class = "form-horizontal" }))
        {
            <div class="row">
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="col-md-4 control-label">Search:</label>
                        <div class="col-md-8">
                            <input type="text" name="searchTerm" value="@searchTerm" class="form-control" placeholder="Search by user, description, entity..." />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-4 control-label">Action Type:</label>
                        <div class="col-md-8">
                            <select name="filterAction" class="form-control">
                                <option value="">-- All Actions --</option>
                                @foreach (var action in ViewBag.Actions as List<string>)
                                {
                                    <option value="@action" @(action == filterAction ? "selected" : "")>@action</option>
                                }
                            </select>
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-4 control-label">Entity Type:</label>
                        <div class="col-md-8">
                            <select name="filterEntity" class="form-control">
                                <option value="">-- All Entities --</option>
                                @foreach (var entity in ViewBag.EntityNames as List<string>)
                                {
                                    <option value="@entity" @(entity == filterEntity ? "selected" : "")>@entity</option>
                                }
                            </select>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="form-group">
                        <label class="col-md-4 control-label">Start Date:</label>
                        <div class="col-md-8">
                            <input type="text" name="startDate" value="@startDate" class="form-control date-picker" placeholder="From Date" />
                        </div>
                    </div>
                    <div class="form-group">
                        <label class="col-md-4 control-label">End Date:</label>
                        <div class="col-md-8">
                            <input type="text" name="endDate" value="@endDate" class="form-control date-picker" placeholder="To Date" />
                        </div>
                    </div>
                    <div class="form-group">
                        <div class="col-md-offset-4 col-md-8">
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-search"></i> Filter
                            </button>
                            <a href="@Url.Action("Index")" class="btn btn-default">
                                <i class="fa fa-refresh"></i> Reset
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered table-hover">
        <thead>
            <tr>
                <th>Date/Time</th>
                <th>User</th>
                <th>Action</th>
                <th>Description</th>
                <th>Entity</th>
                <th>IP Address</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var log in Model)
            {
                <tr>
                    <td>@log.CreatedAt.ToString("yyyy-MM-dd HH:mm:ss")</td>
                    <td>
                        @log.UserName
                    </td>
                    <td>
                        <span class="label @GetActionLabelClass(log.Action)">@log.Action</span>
                    </td>
                    <td>@log.Description</td>
                    <td>
                        @if (!string.IsNullOrEmpty(log.EntityName))
                        {
                            <span>@log.EntityName</span>
                            if (!string.IsNullOrEmpty(log.EntityID))
                            {
                                <span class="text-muted"> (#@log.EntityID)</span>
                            }
                        }
                    </td>
                    <td>@log.IPAddress</td>
                    <td>
                        <a href="@Url.Action("Details", new { id = log.LogID })" class="btn btn-xs btn-info">
                            <i class="fa fa-search"></i> Details
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="text-center">
    @Html.PagedListPager(Model, page => Url.Action("Index", new {
        page,
        searchTerm = searchTerm,
        filterAction = filterAction,
        filterEntity = filterEntity,
        startDate = startDate,
        endDate = endDate
    }))
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            $('.date-picker').datepicker({
                format: 'yyyy-mm-dd',
                autoclose: true,
                todayHighlight: true
            });
        });
    </script>
}

@functions {
    public string GetActionLabelClass(string action)
    {
        switch (action?.ToUpper())
        {
            case "LOGIN":
            case "LOGOUT":
                return "label-default";
            case "CREATE":
                return "label-success";
            case "UPDATE":
                return "label-primary";
            case "DELETE":
                return "label-danger";
            case "VIEW":
                return "label-info";
            default:
                return "label-default";
        }
    }
} 