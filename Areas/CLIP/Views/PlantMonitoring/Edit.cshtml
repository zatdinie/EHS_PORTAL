@model EHS_PORTAL.Areas.CLIP.Models.PlantMonitoring

@{
    ViewBag.Title = "Edit Monitoring Record";
    var isAdmin = User.IsInRole("Admin");
    var currentUser = User.Identity.Name;
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-10">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="card-title mb-0">Edit Monitoring Record</h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @using (Html.BeginForm("Edit", "PlantMonitoring", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate", enctype = "multipart/form-data" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.Id)
                        
                        <div class="mb-4">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">Basic Information</h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3 row">
                                        <label class="col-sm-3 form-label"><strong>Monitoring Type</strong></label>
                                        <div class="col-sm-9">
                                            <div class="input-group">
                                                <select id="MonitoringID" name="MonitoringID" class="form-select" required="required">
                                                                @foreach (var item in (SelectList)ViewBag.MonitoringID)
                                                                {
                                                                    <option value="@item.Value" @(item.Value == Model.MonitoringID.ToString() ? "selected" : "")>@item.Text</option>
                                                                }
                                                            </select>
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Select the monitoring type">
                                                    <i class="bi bi-info-circle"></i>
                                                </span>
                                            </div>
                                            @Html.ValidationMessageFor(model => model.MonitoringID, "", new { @class = "invalid-feedback" })
                                        </div>
                                    </div>
                                    
                                    <div class="mb-3 row">
                                        <label class="col-sm-3 form-label"><strong>Plant</strong></label>
                                        <div class="col-sm-9">
                                            <div class="input-group">
                                                <select id="PlantID" name="PlantID" class="form-select" required="required">
                                                    @foreach (var item in (SelectList)ViewBag.PlantID)
                                                    {
                                                        <option value="@item.Value" @(item.Value == Model.PlantID.ToString() ? "selected" : "")>@item.Text</option>
                                                    }
                                                </select>
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Select the plant location">
                                                    <i class="bi bi-info-circle"></i>
                                                </span>
                                            </div>
                                            @Html.ValidationMessageFor(model => model.PlantID, "", new { @class = "invalid-feedback" })
                                        </div>
                                    </div>
                                    
                                    <div class="mb-3 row">
                                        <label class="col-sm-3 form-label"><strong>Area</strong></label>
                                        <div class="col-sm-9">
                                            <div class="input-group">
                                                @Html.EditorFor(model => model.Area, new { htmlAttributes = new { @class = "form-control", placeholder = "Optional: Specify area (e.g., Chimney 1)" } })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter specific area if applicable">
                                                    <i class="bi bi-info-circle"></i>
                                                </span>
                                            </div>
                                            @Html.ValidationMessageFor(model => model.Area, "", new { @class = "invalid-feedback" })
                                        </div>
                                    </div>
                                    
                                    <div class="mb-3 row">
                                        <label class="col-sm-3 form-label"><strong>Expiry Date</strong></label>
                                        <div class="col-sm-9">
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.ExpDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Will be automatically set based on monitoring frequency when work is completed">
                                                    <i class="bi bi-info-circle"></i>
                                                </span>
                                            </div>
                                            <small class="text-muted">Will be automatically set based on monitoring frequency when work is completed.</small>
                                            @Html.ValidationMessageFor(model => model.ExpDate, "", new { @class = "invalid-feedback" })
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row mb-4">
                            <!-- Quotation Phase -->
                            <div class="col-md-4">
                                <div class="card h-100">
                                    <div class="card-header bg-primary text-white">
                                        <h5 class="mb-0">Quotation Phase</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Start</strong></label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.QuoteDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Date when quotation phase started">
                                                    <i class="bi bi-calendar"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Complete</strong></label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.QuoteCompleteDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Date when quotation phase was completed">
                                                    <i class="bi bi-calendar-check"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Assigned</strong></label>
                                            <div class="input-group">
                                                @if (isAdmin)
                                                {
                                                    @Html.DropDownList("QuoteUserAssign", (SelectList)ViewBag.UsersList, new { @class = "form-select" })
                                                }
                                                else
                                                {
                                                    <input type="text" name="QuoteUserAssign" value="@(string.IsNullOrEmpty(Model.QuoteUserAssign) ? currentUser : Model.QuoteUserAssign)" class="form-control" readonly />
                                                }
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="User assigned to quotation phase">
                                                    <i class="bi bi-person"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Document</strong></label>
                                            <div>
                                                @if (!string.IsNullOrEmpty(Model.QuoteDoc))
                                                {
                                                    <div class="mb-2">
                                                        <a href="@Url.Content(Model.QuoteDoc)" target="_blank" class="btn btn-sm btn-info">
                                                            <i class="fas fa-file-download me-1"></i> View Current Document
                                                        </a>
                                                        @Html.HiddenFor(model => model.QuoteDoc)
                                                    </div>
                                                }
                                                <div class="input-group">
                                                    <input type="file" name="quoteDocument" class="form-control" />
                                                    <span class="input-group-text" data-bs-toggle="tooltip" title="Upload a new document for quotation phase">
                                                        <i class="bi bi-upload"></i>
                                                    </span>
                                                </div>
                                                <small class="text-muted">Leave empty to keep current document</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Preparation Phase -->
                            <div class="col-md-4">
                                <div class="card h-100">
                                    <div class="card-header bg-warning text-white">
                                        <h5 class="mb-0">Raise ePR Phase</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Start</strong></label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.EprDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Date when ePR phase started">
                                                    <i class="bi bi-calendar"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Complete</strong></label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.EprCompleteDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Date when ePR phase was completed">
                                                    <i class="bi bi-calendar-check"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Assigned</strong></label>
                                            <div class="input-group">
                                                @if (isAdmin)
                                                {
                                                    @Html.DropDownList("EprUserAssign", (SelectList)ViewBag.UsersList, new { @class = "form-select" })
                                                }
                                                else
                                                {
                                                    <input type="text" name="EprUserAssign" value="@(string.IsNullOrEmpty(Model.EprUserAssign) ? currentUser : Model.EprUserAssign)" class="form-control" readonly />
                                                }
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="User assigned to ePR phase">
                                                    <i class="bi bi-person"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Document</strong></label>
                                            <div>
                                                @if (!string.IsNullOrEmpty(Model.EprDoc))
                                                {
                                                    <div class="mb-2">
                                                        <a href="@Url.Content(Model.EprDoc)" target="_blank" class="btn btn-sm btn-info">
                                                            <i class="fas fa-file-download me-1"></i> View Current Document
                                                        </a>
                                                        @Html.HiddenFor(model => model.EprDoc)
                                                    </div>
                                                }
                                                <div class="input-group">
                                                    <input type="file" name="eprDocument" class="form-control" />
                                                    <span class="input-group-text" data-bs-toggle="tooltip" title="Upload a new document for ePR phase">
                                                        <i class="bi bi-upload"></i>
                                                    </span>
                                                </div>
                                                <small class="text-muted">Leave empty to keep current document</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                            
                            <!-- Work Execution Phase -->
                            <div class="col-md-4">
                                <div class="card h-100">
                                    <div class="card-header bg-success text-white">
                                        <h5 class="mb-0">Work Execution Phase</h5>
                                    </div>
                                    <div class="card-body">
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Start</strong></label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.WorkDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Date when work execution started">
                                                    <i class="bi bi-calendar"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Submit</strong></label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.WorkSubmitDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Date when work was submitted">
                                                    <i class="bi bi-calendar"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Complete</strong></label>
                                            <div class="input-group">
                                                @Html.TextBoxFor(model => model.WorkCompleteDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="Date when work was completed">
                                                    <i class="bi bi-calendar-check"></i>
                                                </span>
                                            </div>
                                            <small class="text-muted">When completed, renewal date will be set based on monitoring frequency.</small>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Assigned</strong></label>
                                            <div class="input-group">
                                                @if (isAdmin)
                                                {
                                                    @Html.DropDownList("WorkUserAssign", (SelectList)ViewBag.UsersList, new { @class = "form-select" })
                                                }
                                                else
                                                {
                                                    <input type="text" name="WorkUserAssign" value="@(string.IsNullOrEmpty(Model.WorkUserAssign) ? currentUser : Model.WorkUserAssign)" class="form-control" readonly />
                                                }
                                                <span class="input-group-text" data-bs-toggle="tooltip" title="User assigned to work execution">
                                                    <i class="bi bi-person"></i>
                                                </span>
                                            </div>
                                        </div>
                                        
                                        <div class="mb-3">
                                            <label class="form-label"><strong>Document</strong></label>
                                            <div>
                                                @if (!string.IsNullOrEmpty(Model.WorkDoc))
                                                {
                                                    <div class="mb-2">
                                                        <a href="@Url.Content(Model.WorkDoc)" target="_blank" class="btn btn-sm btn-info">
                                                            <i class="fas fa-file-download me-1"></i> View Current Document
                                                        </a>
                                                        @Html.HiddenFor(model => model.WorkDoc)
                                                    </div>
                                                }
                                                <div class="input-group">
                                                    <input type="file" name="workDocument" class="form-control" />
                                                    <span class="input-group-text" data-bs-toggle="tooltip" title="Upload a new document for work execution phase">
                                                        <i class="bi bi-upload"></i>
                                                    </span>
                                                </div>
                                                <small class="text-muted">Leave empty to keep current document</small>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-4">
                            <div class="card">
                                <div class="card-header bg-light">
                                    <h5 class="mb-0">Remarks</h5>
                                </div>
                                <div class="card-body">
                                    <div class="mb-3">
                                        <div class="input-group">
                                            @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", rows = 3 })
                                            <span class="input-group-text" data-bs-toggle="tooltip" title="Additional notes about this monitoring record">
                                                <i class="bi bi-info-circle"></i>
                                            </span>
                                        </div>
                                        @Html.ValidationMessageFor(model => model.Remarks, "", new { @class = "invalid-feedback" })
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="mt-4 d-flex justify-content-between">
                            @Html.ActionLink("Back to Details", "Details", new { id = Model.Id }, new { @class = "btn btn-outline-secondary" })
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script>
        $(function () {
            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();
            
            // Set the correct plant value
            var plantId = @Model.PlantID;
            $("#PlantID").val(plantId);
            
            // Bootstrap form validation
            (function () {
                'use strict'
                var forms = document.querySelectorAll('.needs-validation')
                Array.prototype.slice.call(forms)
                    .forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
            })()
        });
    </script>
} 