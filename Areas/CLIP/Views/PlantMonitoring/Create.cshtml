@model EHS_PORTAL.Areas.CLIP.Models.PlantMonitoring

@{
    ViewBag.Title = "Create Monitoring Record";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="card-title mb-0">Create Monitoring Record</h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @using (Html.BeginForm("Create", "PlantMonitoring", FormMethod.Post, new { @class = "needs-validation", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary(true, "", new { @class = "text-danger" })
                        
                        <div class="mb-3">
                            <label for="MonitoringID" class="form-label"><strong>Monitoring Type</strong></label>
                            <div class="input-group">
                                @Html.DropDownList("MonitoringID", (SelectList)ViewBag.MonitoringID, "-- Select Monitoring Type --", new { @class = "form-select", required = "required" })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Select the monitoring type">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.MonitoringID, "", new { @class = "invalid-feedback" })
                        </div>
                        
                        <div class="mb-3">
                            <label for="PlantID" class="form-label"><strong>Plant</strong></label>
                            <div class="input-group">
                                @Html.DropDownList("PlantID", (SelectList)ViewBag.PlantID, "-- Select Plant --", new { @class = "form-select", required = "required" })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Select the plant location">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.PlantID, "", new { @class = "invalid-feedback" })
                        </div>
                        
                        <div class="mb-3">
                            <label for="Area" class="form-label"><strong>Area</strong></label>
                            <div class="input-group">
                                @Html.EditorFor(model => model.Area, new { htmlAttributes = new { @class = "form-control", placeholder = "Optional: Specify area (e.g., Chimney 1)" } })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Specific area within the plant">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.Area, "", new { @class = "invalid-feedback" })
                        </div>
                        
                        <div class="mb-3">
                            <label for="ExpDate" class="form-label"><strong>Expiry Date</strong></label>
                            <div class="input-group">
                                @Html.TextBoxFor(model => model.ExpDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Will be automatically set based on monitoring frequency when work is completed">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            <small class="text-muted">Will be automatically set based on monitoring frequency when work is completed.</small>
                            @Html.ValidationMessageFor(model => model.ExpDate, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="card mb-4">
                            <div class="card-header bg-light">
                                <h5 class="mb-0">Project Phases</h5>
                            </div>
                            <div class="card-body">
                                <div class="row">
                                    <!-- Quotation Phase -->
                                    <div class="col-md-4">
                                        <div class="card mb-3">
                                            <div class="card-header bg-primary text-white">
                                                <h6 class="mb-0">Quotation Phase</h6>
                                            </div>
                                            <div class="card-body">
                                                <div class="mb-3">
                                                    <label for="QuoteDate" class="form-label"><strong>Start Date</strong></label>
                                                    @Html.TextBoxFor(model => model.QuoteDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                </div>
                                                
                                                <div class="mb-3">
                                                    <label for="QuoteUserAssign" class="form-label"><strong>Assigned To</strong></label>
                                                    @Html.DropDownList("QuoteUserAssign", (SelectList)ViewBag.UsersList, "-- Select User --", new { @class = "form-select" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Preparation Phase -->
                                    <div class="col-md-4">
                                        <div class="card mb-3">
                                            <div class="card-header bg-warning text-white">
                                                <h6 class="mb-0">Raise ePR Phase</h6>
                                            </div>
                                            <div class="card-body">
                                                <div class="mb-3">
                                                    <label for="EprDate" class="form-label"><strong>Start Date</strong></label>
                                                    @Html.TextBoxFor(model => model.EprDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                </div>
                                                
                                                <div class="mb-3">
                                                    <label for="EprUserAssign" class="form-label"><strong>Assigned To</strong></label>
                                                    @Html.DropDownList("EprUserAssign", (SelectList)ViewBag.UsersList, "-- Select User --", new { @class = "form-select" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                    
                                    <!-- Work Execution Phase -->
                                    <div class="col-md-4">
                                        <div class="card mb-3">
                                            <div class="card-header bg-success text-white">
                                                <h6 class="mb-0">Work Execution Phase</h6>
                                            </div>
                                            <div class="card-body">
                                                <div class="mb-3">
                                                    <label for="WorkDate" class="form-label"><strong>Start Date</strong></label>
                                                    @Html.TextBoxFor(model => model.WorkDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                </div>
                                                
                                                <div class="mb-3">
                                                    <label for="WorkCompleteDate" class="form-label"><strong>Complete Date</strong></label>
                                                    @Html.TextBoxFor(model => model.WorkCompleteDate, "{0:yyyy-MM-dd}", new { @class = "form-control", type = "date" })
                                                    <small class="text-muted">When completed, renewal date will be set based on monitoring frequency.</small>
                                                </div>
                                                
                                                <div class="mb-3">
                                                    <label for="WorkUserAssign" class="form-label"><strong>Assigned To</strong></label>
                                                    @Html.DropDownList("WorkUserAssign", (SelectList)ViewBag.UsersList, "-- Select User --", new { @class = "form-select" })
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="Remarks" class="form-label"><strong>Remarks</strong></label>
                            <div class="input-group">
                                @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", rows = 3 })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Additional notes about this monitoring record">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.Remarks, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mt-4 d-flex justify-content-between">
                            <a href="@Url.Action("Index", "PlantMonitoring")" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Create Monitoring Record
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script>
        $(function () {
            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();
            
            // Bootstrap form validation
            (function () {
                'use strict'
                var forms = document.querySelectorAll('.needs-validation')
                Array.prototype.slice.call(forms)
                    .forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
            })()
        });
    </script>
} 