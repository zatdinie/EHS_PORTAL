@model EHS_PORTAL.Areas.CLIP.Models.PlantMonitoring

@{
    ViewBag.Title = "Plant Monitoring Details";
    var isAdmin = ViewBag.IsAdmin;
}

<br/>
<h1>Plant Monitoring Details</h1>

@if (ViewBag.Notifications != null)
{
    @Html.Partial("_MonitoringNotifications", (List<EHS_PORTAL.Areas.CLIP.Models.MonitoringNotification>)ViewBag.Notifications)
}

<!-- Alert Messages -->
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="fas fa-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card shadow-sm mb-4">
    <div class="card-body">
        <div class="row mb-3">
            <div class="col-md-3 fw-bold">
                Monitoring Type
            </div>
            <div class="col-md-9">
                @Model.Monitoring.MonitoringName
            </div>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-3 fw-bold">
                Category
            </div>
            <div class="col-md-9">
                @Model.Monitoring.MonitoringCategory
            </div>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-3 fw-bold">
                Frequency
            </div>
            <div class="col-md-9">
                @Model.Monitoring.MonitoringFreq
            </div>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-3 fw-bold">
                Plant
            </div>
            <div class="col-md-9">
                @Model.Plant.PlantName
            </div>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-3 fw-bold">
                Area
            </div>
            <div class="col-md-9">
                @Model.Area
            </div>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-3 fw-bold">
                Expiry Date
            </div>
            <div class="col-md-9">
                @if (Model.ExpDate.HasValue)
                {
                    @Model.ExpDate.Value.ToString("MM/dd/yyyy")
                }
                else
                {
                    <span>Not set</span>
                }
            </div>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-3 fw-bold">
                Process Status
            </div>
            <div class="col-md-9">
                <span class="text-black badge @Model.ProcStatusCssClass">@Model.ProcStatus</span>
            </div>
        </div>
        
        <div class="row mb-3">
            <div class="col-md-3 fw-bold">
                Expiration Status
            </div>
            <div class="col-md-9">
                <span class="badge @Model.ExpStatusCssClass">@Model.ExpStatus</span>
            </div>
        </div>
        
        @if (!string.IsNullOrEmpty(Model.Remarks))
        {
            <div class="row mb-3">
                <div class="col-md-3 fw-bold">
                    Remarks
                </div>
                <div class="col-md-9">
                    @Model.Remarks
                </div>
            </div>
        }

        <div class="mt-4">
            <a href="@Url.Action("Index")" class="btn btn-secondary">
                <i class="fas fa-arrow-left me-1"></i> Back to List
            </a>
            
            @if (Model.ExpStatus == "Expiring Soon" || Model.ExpStatus == "Expired")
            {
                using (Html.BeginForm("RenewMonitoring", "PlantMonitoring", new { id = Model.Id }, FormMethod.Post, new { style = "display:inline;" }))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-warning" onclick="return confirm('Are you sure you want to renew this monitoring item? This will create a new monitoring cycle.');">
                        <i class="fas fa-sync-alt me-1"></i> Renew Monitoring
                    </button>
                }
            }
            <a href="@Url.Action("UpdateStatus", new { id = Model.Id })" class="btn btn-primary">
                <i class="fas fa-edit me-1"></i> Update Status
            </a>
            @if (isAdmin)
            {
                <a href="@Url.Action("Edit", new { id = Model.Id })" class="btn btn-warning">
                    <i class="fas fa-pencil-alt me-1"></i> Edit
                </a>
                <a href="@Url.Action("Delete", new { id = Model.Id })" class="btn btn-danger">
                    <i class="fas fa-trash me-1"></i> Delete
                </a>
            }
        </div>
    </div>
</div>

<div class="row">
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Quotation Phase</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Start Date:</div>
                    <div class="col-md-6">
                        @(Model.QuoteDate.HasValue ? Model.QuoteDate.Value.ToString("MM/dd/yyyy") : "Not started")
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Completion:</div>
                    <div class="col-md-6">
                        @(Model.QuoteCompleteDate.HasValue ? Model.QuoteCompleteDate.Value.ToString("MM/dd/yyyy") : "Not completed")
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Assigned To:</div>
                    <div class="col-md-6">
                        @(string.IsNullOrEmpty(Model.QuoteUserAssign) ? "Not assigned" : Model.QuoteUserAssign)
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Document:</div>
                    <div class="col-md-6">
                        @if (!string.IsNullOrEmpty(Model.QuoteDoc))
                        {
                            <a href="@Url.Content(Model.QuoteDoc)" target="_blank" class="btn btn-sm btn-info" title="View Document">
                                <i class="fas fa-file-download"></i>
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No document</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-warning text-white">
                <h5 class="mb-0">Raise ePR Phase</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Start Date:</div>
                    <div class="col-md-6">
                        @(Model.EprDate.HasValue ? Model.EprDate.Value.ToString("MM/dd/yyyy") : "Not started")
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Completion:</div>
                    <div class="col-md-6">
                        @(Model.EprCompleteDate.HasValue ? Model.EprCompleteDate.Value.ToString("MM/dd/yyyy") : "Not completed")
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Assigned To:</div>
                    <div class="col-md-6">
                        @(string.IsNullOrEmpty(Model.EprUserAssign) ? "Not assigned" : Model.EprUserAssign)
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Document:</div>
                    <div class="col-md-6">
                        @if (!string.IsNullOrEmpty(Model.EprDoc))
                        {
                            <a href="@Url.Content(Model.EprDoc)" target="_blank" class="btn btn-sm btn-info" title="View Document">
                                <i class="fas fa-file-download"></i>
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No document</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-success text-white">
                <h5 class="mb-0">Work Execution Phase</h5>
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Start Date:</div>
                    <div class="col-md-6">
                        @(Model.WorkDate.HasValue ? Model.WorkDate.Value.ToString("MM/dd/yyyy") : "Not started")
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Submission:</div>
                    <div class="col-md-6">
                        @(Model.WorkSubmitDate.HasValue ? Model.WorkSubmitDate.Value.ToString("MM/dd/yyyy") : "Not submitted")
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Completion:</div>
                    <div class="col-md-6">
                        @(Model.WorkCompleteDate.HasValue ? Model.WorkCompleteDate.Value.ToString("MM/dd/yyyy") : "Not completed")
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Assigned To:</div>
                    <div class="col-md-6">
                        @(string.IsNullOrEmpty(Model.WorkUserAssign) ? "Not assigned" : Model.WorkUserAssign)
                    </div>
                </div>
                
                <div class="row mb-3">
                    <div class="col-md-6 fw-bold">Document:</div>
                    <div class="col-md-6">
                        @if (!string.IsNullOrEmpty(Model.WorkDoc))
                        {
                            <a href="@Url.Content(Model.WorkDoc)" target="_blank" class="btn btn-sm btn-info" title="View Document">
                                <i class="fas fa-file-download"></i>
                            </a>
                        }
                        else
                        {
                            <span class="text-muted">No document</span>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div> 