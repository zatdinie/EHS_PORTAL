@using System.Linq
@{
    ViewBag.Title = "Progress Tracker";
    var monitoringTypes = ViewBag.MonitoringTypes;
    var plants = ViewBag.Plants;
    var data = ViewBag.Data;
    var currentYear = ViewBag.CurrentYear;
    var monthNames = ViewBag.MonthNames;
    var isAdmin = ViewBag.IsAdmin;
    
    // Calculate stats for the dashboard
    int typeCount = monitoringTypes?.Count ?? 0;
    
    int inProgressCount = 0;
    int completedCount = 0;
    int expiredCount = 0;
    int notStartedCount = 0;
    int totalRecordsCount = 0;
    
    foreach (var m in monitoringTypes)
    {
        if (!data.ContainsKey(m.MonitoringID)) { continue; }
        foreach (var plantId in data[m.MonitoringID].Keys)
        {
            foreach (var r in data[m.MonitoringID][plantId]) 
            {
                totalRecordsCount++;
                
                if (r.ProcStatus == "Work In Progress" || r.ProcStatus == "ePR Raised" || r.ProcStatus == "Quotation Requested")
                {
                    inProgressCount++;
                }
                else if (r.ProcStatus == "Completed")
                {
                    completedCount++;
                }
                else if (r.ProcStatus == "Not Started")
                {
                    notStartedCount++;
                }
                
                if (r.ExpStatus == "Expired")
                {
                    expiredCount++;
                }
            }
        }
    }
    
    // Calculate percentages for dashboard cards
    int inProgressPercent = totalRecordsCount > 0 ? (int)Math.Round((double)inProgressCount / totalRecordsCount * 100) : 0;
    int completedPercent = totalRecordsCount > 0 ? (int)Math.Round((double)completedCount / totalRecordsCount * 100) : 0;
    int expiredPercent = totalRecordsCount > 0 ? (int)Math.Round((double)expiredCount / totalRecordsCount * 100) : 0;
    int notStartedPercent = totalRecordsCount > 0 ? (int)Math.Round((double)notStartedCount / totalRecordsCount * 100) : 0;

    // Group monitoring types by category - using loops instead of lambda expressions
    var monitoringByCategory = new Dictionary<string, List<dynamic>>();
    
    foreach (var m in monitoringTypes)
    {
        string category = m.MonitoringCategory ?? string.Empty;
        
        if (!monitoringByCategory.ContainsKey(category))
        {
            monitoringByCategory[category] = new List<dynamic>();
        }
        
        monitoringByCategory[category].Add(m);
    }
}

<div class="container-fluid py-4">
    <!-- Header Section -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>Progress Tracker</h1>
            <div class="d-flex gap-2 justify-content-end">
                @if (User.IsInRole("Admin"))
                {
                    <a href="@Url.Action("Create")" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i> Add New Record
                    </a>
                }
            </div>
    </div>

   
    <!-- Alert Messages -->
    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }


    <!-- Progress Trackers -->
    <div id="progressTrackers">
        <div class="mb-3">
            <div class="d-flex flex-wrap gap-2">
                <a href="@Url.Action("Schedule", "PlantMonitoring", new { plantFilter = "" })"
                    class="btn @(ViewBag.SelectedPlantFilter == null || ViewBag.SelectedPlantFilter == "" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-buildings"></i> All Plants
                </a>
                <a href="@Url.Action("Schedule", "PlantMonitoring", new { plantFilter = "1,3,6" })"
                    class="btn @(ViewBag.SelectedPlantFilter != null && ViewBag.SelectedPlantFilter.ToString() == "1,3,6" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-buildings"></i> P1, P3, P5
                </a>
                <a href="@Url.Action("Schedule", "PlantMonitoring", new { plantFilter = "4" })"
                    class="btn @(ViewBag.SelectedPlantFilter != null && ViewBag.SelectedPlantFilter.ToString() == "4" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-buildings"></i> P21
                </a>
                <a href="@Url.Action("Schedule", "PlantMonitoring", new { plantFilter = "2,7" })"
                    class="btn @(ViewBag.SelectedPlantFilter != null && ViewBag.SelectedPlantFilter.ToString() == "2,7" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-buildings"></i> P13, P55
                </a>
                <a href="@Url.Action("Schedule", "PlantMonitoring", new { plantFilter = "5" })"
                    class="btn @(ViewBag.SelectedPlantFilter != null && ViewBag.SelectedPlantFilter.ToString() == "5" ? "btn-primary" : "btn-outline-primary")">
                    <i class="bi bi-buildings"></i> P34
                </a>
            </div>
            @if (ViewBag.SelectedPlantFilter != null && !string.IsNullOrEmpty(ViewBag.SelectedPlantFilter.ToString()))
            {
                <div class="mt-2 small text-muted">
                    
                </div>
            }
        </div>

        <div class="card shadow-sm mb-4">
            <div class="card-header bg-light p-3">
                <h5 class="card-title mb-3">Filter</h5>
                <div class="row g-3">
                    <div class="col-md-6">
                        <label for="searchInput" class="form-label small text-muted">Search</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted">
                                <i class="bi bi-search"></i>
                            </span>
                            <input type="text" id="searchInput" class="form-control border-start-0" placeholder="Search by monitoring type or area...">
                        </div>
                    </div>
                    <div class="col-md-6">
                        <label for="statusFilter" class="form-label small text-muted">Status</label>
                        <select id="statusFilter" class="form-select">
                            <option value="">-- All Statuses --</option>
                            <option value="Not Started">Not Started</option>
                            <option value="Quotation Requested">Quotation Requested</option>
                            <option value="ePR Raised">ePR Raised</option>
                            <option value="Work In Progress">Work In Progress</option>
                            <option value="Completed">Completed</option>
                        </select>
                    </div>
                </div>
            </div>
            
            @{
                bool hasRecords = monitoringByCategory.Any();
                
                if (!hasRecords)
                {
                    <div class="alert alert-info shadow m-3">
                        <div class="d-flex align-items-center">
                            <div class="me-3">
                                <i class="bi bi-info-circle fs-3"></i>
                            </div>
                            <div>
                                <h4 class="alert-heading mb-1">No monitoring records found</h4>
                                <p class="mb-0">There are currently no monitoring records to display. Please add some records to see them here.</p>
                            </div>
                        </div>
                    </div>
                }
                else
                {
                    foreach (var category in monitoringByCategory)
                    {
                        var categoryName = category.Key;
                        var categoryModules = category.Value;
                        
                        <div class="category-section" id="@(categoryName.ToLower().Replace(" ", "-"))-section">
                            <div class="category-header bg-primary bg-opacity-10 p-3 border-top border-bottom">
                                <h3 class="mb-0 d-flex align-items-center">
                                    @if (categoryName.ToLower() == "environment")
                                    {
                                        <i class="bi bi-tree text-success me-2"></i>
                                    }
                                    else if (categoryName.ToLower() == "health & safety")
                                    {
                                        <i class="bi bi-shield-check text-danger me-2"></i>
                                    }
                                    else
                                    {
                                        <i class="bi bi-clipboard-data text-warning me-2"></i>
                                    }
                                    @categoryName.ToUpper()
                                </h3>
                            </div>
                            
                            <div class="monitoring-list">
                                @if (categoryName.ToLower() == "environment" || categoryName.ToLower() == "health & safety")
                                {
                                    <!-- Accordion style for Environment and Health & Safety with grouped monitoring types -->
                                    <div class="accordion" id="@(categoryName.ToLower().Replace(" ", "-"))Accordion">
                                        @foreach (var monitoring in categoryModules)
                                        {
                                            if (!data.ContainsKey(monitoring.MonitoringID) || data[monitoring.MonitoringID].Keys.Count == 0)
                                            {
                                                continue;
                                            }
                                            
                                            string monitoringId = $"monitoring-{monitoring.MonitoringID}";
                                            
                                            // Calculate stats for this monitoring type
                                            int typeRecords = 0;
                                            int typeInProgress = 0;
                                            int typeCompleted = 0;
                                            int typeExpired = 0;
                                            int typeNotStarted = 0;
                                            
                                            foreach (var plantId in data[monitoring.MonitoringID].Keys)
                                            {
                                                foreach (var record in data[monitoring.MonitoringID][plantId])
                                                {
                                                    typeRecords++;
                                                    
                                                    if (record.ProcStatus == "Work In Progress" || record.ProcStatus == "ePR Raised" || record.ProcStatus == "Quotation Requested")
                                                    {
                                                        typeInProgress++;
                                                    }
                                                    else if (record.ProcStatus == "Completed")
                                                    {
                                                        typeCompleted++;
                                                    }
                                                    else if (record.ProcStatus == "Not Started")
                                                    {
                                                        typeNotStarted++;
                                                    }
                                                    
                                                    if (record.ExpStatus == "Expired")
                                                    {
                                                        typeExpired++;
                                                    }
                                                }
                                            }
                                            
                                            // Calculate percentages
                                            int typeInProgressPercent = typeRecords > 0 ? (int)Math.Round((double)typeInProgress / typeRecords * 100) : 0;
                                            int typeCompletedPercent = typeRecords > 0 ? (int)Math.Round((double)typeCompleted / typeRecords * 100) : 0;
                                            int typeExpiredPercent = typeRecords > 0 ? (int)Math.Round((double)typeExpired / typeRecords * 100) : 0;
                                            int typeNotStartedPercent = typeRecords > 0 ? (int)Math.Round((double)typeNotStarted / typeRecords * 100) : 0;
                                            
                                            <div class="accordion-item border-0 border-bottom monitoring-item">
                                                <h2 class="accordion-header" id="heading-@monitoringId">
                                                    <button class="accordion-button collapsed py-3" type="button" data-bs-toggle="collapse" 
                                                            data-bs-target="#@monitoringId" aria-expanded="false" aria-controls="@monitoringId">
                                                        <div class="d-flex justify-content-between align-items-center w-100 me-3">
                                                                                                                            <div class="d-flex flex-column">
                                                                <div class="d-flex align-items-center">
                                                                    <strong class="fs-5 text-dark fw-bold">@monitoring.MonitoringName</strong>
                                                                </div>
                                                            </div>
                                                            <div class="d-flex gap-2">
                                                                @if (typeCompleted > 0)
                                                                {
                                                                    <span class="badge bg-success text-white shadow-sm px-2 py-1" data-bs-toggle="tooltip" 
                                                                          title="Completed">
                                                                        <i class="bi bi-check-circle me-1"></i> @typeCompleted
                                                                    </span>
                                                                }
                                                                @if (typeInProgress > 0)
                                                                {
                                                                    <span class="badge bg-info text-white shadow-sm px-2 py-1" data-bs-toggle="tooltip" 
                                                                          title="In Progress">
                                                                        <i class="bi bi-hourglass-split me-1"></i> @typeInProgress
                                                                    </span>
                                                                }
                                                                @if (typeExpired > 0)
                                                                {
                                                                    <span class="badge bg-danger text-white shadow-sm px-2 py-1" data-bs-toggle="tooltip" 
                                                                          title="Expired">
                                                                        <i class="bi bi-exclamation-circle me-1"></i> @typeExpired
                                                                    </span>
                                                                }
                                                            </div>
                                                        </div>
                                                    </button>
                                                </h2>
                                                <div id="@monitoringId" class="accordion-collapse collapse" aria-labelledby="heading-@monitoringId">
                                                    <div class="accordion-body p-0">
                                                        <table class="table table-hover mb-0">
                                                            <thead class="table-light">
                                                                <tr>
                                                                    <th class="ps-3">Plant</th>
                                                                    <th>Area</th>
                                                                    <th>Status</th>
                                                                    <th>Expiry</th>
                                                                    <th class="text-center">Actions</th>
                                                                </tr>
                                                            </thead>
                                                            <tbody>
                                                                @foreach (var plantId in data[monitoring.MonitoringID].Keys)
                                                                {
                                                                    var plantFound = null as dynamic;
                                                                    foreach (var p in plants)
                                                                    {
                                                                        if (p.Id == plantId)
                                                                        {
                                                                            plantFound = p;
                                                                            break;
                                                                        }
                                                                    }
                                                                                
                                                                    if (plantFound == null) { continue; }
                                                                    
                                                                    foreach (var record in data[monitoring.MonitoringID][plantId])
                                                                    {
                                                                        <tr>
                                                                            <td class="ps-3">
                                                                                <span class="fw-medium">@plantFound.PlantName</span>
                                                                            </td>
                                                                            <td>
                                                                                @if (!string.IsNullOrEmpty(record.Area))
                                                                                {
                                                                                    <span class="badge bg-light text-dark">@record.Area</span>
                                                                                }
                                                                                else
                                                                                {
                                                                                    <span class="text-muted">-</span>
                                                                                }
                                                                            </td>
                                                                            <td>
                                                                                <span class="badge @(record.ProcStatus == "Not Started" ? "bg-secondary" : record.ProcStatusCssClass) text-white" 
                                                                                      data-bs-toggle="tooltip" data-bs-html="true" title="@GetStatusTooltip(record)">
                                                                                    @record.ProcStatus
                                                                                </span>
                                                                            </td>
                                                                            <td>
                                                                                <span class="badge @record.ExpStatusCssClass text-white" data-bs-toggle="tooltip" data-bs-html="true"
                                                                                      title="@GetExpiryTooltip(record)">
                                                                                    @record.ExpStatus
                                                                                    @{
                                                                                        try 
                                                                                        {
                                                                                            if (record.ExpDate != null && record.ExpDate != DateTime.MinValue)
                                                                                            {
                                                                                                <span> - @record.ExpDate.Value.ToString("dd/MM/yyyy")</span>
                                                                                            }
                                                                                        }
                                                                                        catch { /* Ignore conversion errors */ }
                                                                                    }
                                                                                </span>
                                                                            </td>
                                                                            <td class="text-center">
                                                                                <div class="btn-group">
                                                                                    @if (!string.IsNullOrEmpty(record.Remarks))
                                                                                    {
                                                                                        <button type="button" class="btn btn-info btn-sm" data-bs-toggle="tooltip" data-bs-html="true" 
                                                                                                title="<strong>Remarks:</strong><br>@record.Remarks.Replace("\n", "<br>")">
                                                                                            <i class="bi bi-chat-dots"></i>
                                                                                        </button>
                                                                                    }
                                                                                    <a href="@Url.Action("Details", new { id = record.Id })" class="btn btn-sm btn-info" title="View Details" data-bs-toggle="tooltip">
                                                                                        <i class="bi bi-info-circle"></i>
                                                                                    </a>
                                                                                    @if (User.IsInRole("Admin") || (ViewBag.UserPlantIds != null && ViewBag.UserPlantIds.Contains(plantId)))
                                                                                    {
                                                                                        <a href="@Url.Action("UpdateStatus", new { id = record.Id })" class="btn btn-sm btn-primary" title="Update Status" data-bs-toggle="tooltip">
                                                                                            <i class="bi bi-pencil-square"></i>
                                                                                        </a>
                                                                                    }
                                                                                    else
                                                                                    {
                                                                                        <button class="btn btn-sm btn-secondary disabled" title="You don't have access to update this plant" data-bs-toggle="tooltip">
                                                                                            <i class="bi bi-pencil-square"></i>
                                                                                        </button>
                                                                                    }
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                        <tr>
                                                                            <td colspan="5" class="p-0 border-0">
                                                                                <!-- Progress Timeline -->
                                                                                <div class="progress-tracker-container p-3">
                                                                                    <div class="progress-tracker-horizontal">
                                                                                        <!-- Progress Track Line with completion percentage -->
                                                                                        <div class="progress-track-line">
                                                                                            @{
                                                                                                int completionPercentage = 0;
                                                                                                if (GetCurrentStage(record) == 0) { completionPercentage = 0; }
                                                                                                else if (GetCurrentStage(record) == 1) { completionPercentage = 25; }
                                                                                                else if (GetCurrentStage(record) == 2) { completionPercentage = 50; }
                                                                                                else if (GetCurrentStage(record) == 3) { completionPercentage = 75; }
                                                                                                else if (GetCurrentStage(record) == 4) { completionPercentage = 100; }
                                                                                            }
                                                                                            <div class="progress-track-completion" style="width: @completionPercentage%;"></div>
                                                                                        </div>
                                                                                        
                                                                                        <!-- Quotation Stage -->
                                                                                        <div class="progress-step-container">
                                                                                            <div class="progress-circle @(GetStepComplete(record, 1) ? "completed" : GetStepActive(record, 1) ? "active" : "")" 
                                                                                                 data-bs-toggle="tooltip" data-bs-html="true" title="@GetQuotationTooltip(record)">
                                                                                                <i class="bi bi-file-earmark-text"></i>
                                                                                                @if (GetStepComplete(record, 1))
                                                                                                {
                                                                                                    <span class="check-icon"><i class="bi bi-check"></i></span>
                                                                                                }
                                                                                            </div>
                                                                                            <div class="progress-label">Quotation Request</div>
                                                                                            <div class="progress-date">
                                                                                                @{
                                                                                                    try 
                                                                                                    {
                                                                                                        if (record.QuoteDate != null && record.QuoteDate != DateTime.MinValue)
                                                                                                        {
                                                                                                            @record.QuoteDate.ToString("dd/MM/yyyy")
                                                                                                        }
                                                                                                        else
                                                                                                        {
                                                                                                            <span class="text-muted">Not started</span>
                                                                                                        }
                                                                                                    }
                                                                                                    catch 
                                                                                                    {
                                                                                                        <span class="text-muted">Not started</span>
                                                                                                    }
                                                                                                }
                                                                                            </div>
                                                                                        </div>
                                                                                        
                                                                                        <!-- Preparation Stage -->
                                                                                        <div class="progress-step-container">
                                                                                            <div class="progress-circle @(GetStepComplete(record, 2) ? "completed" : GetStepActive(record, 2) ? "active" : "")"
                                                                                                 data-bs-toggle="tooltip" data-bs-html="true" title="@GetPreparationTooltip(record)">
                                                                                                <i class="bi bi-clipboard-check"></i>
                                                                                                @if (GetStepComplete(record, 2))
                                                                                                {
                                                                                                    <span class="check-icon"><i class="bi bi-check"></i></span>
                                                                                                }
                                                                                            </div>
                                                                                            <div class="progress-label">ePR Raised</div>
                                                                                            <div class="progress-date">
                                                                                                @{
                                                                                                    try 
                                                                                                    {
                                                                                                        if (record.EprDate != null && record.EprDate != DateTime.MinValue)
                                                                                                        {
                                                                                                            @record.EprDate.ToString("dd/MM/yyyy")
                                                                                                        }
                                                                                                        else
                                                                                                        {
                                                                                                            <span class="text-muted">Not started</span>
                                                                                                        }
                                                                                                    }
                                                                                                    catch 
                                                                                                    {
                                                                                                        <span class="text-muted">Not started</span>
                                                                                                    }
                                                                                                }
                                                                                            </div>
                                                                                        </div>
                                                                                        
                                                                                        <!-- Work Stage -->
                                                                                        <div class="progress-step-container">
                                                                                            <div class="progress-circle @(GetStepComplete(record, 3) ? "completed" : GetStepActive(record, 3) ? "active" : "")"
                                                                                                 data-bs-toggle="tooltip" data-bs-html="true" title="@GetWorkTooltip(record)">
                                                                                                <i class="bi bi-tools"></i>
                                                                                                @if (GetStepComplete(record, 3))
                                                                                                {
                                                                                                    <span class="check-icon"><i class="bi bi-check"></i></span>
                                                                                                }
                                                                                            </div>
                                                                                            <div class="progress-label">Work Execution</div>
                                                                                            <div class="progress-date">
                                                                                                @{
                                                                                                    try 
                                                                                                    {
                                                                                                        if (record.WorkDate != null && record.WorkDate != DateTime.MinValue)
                                                                                                        {
                                                                                                            @record.WorkDate.ToString("dd/MM/yyyy")
                                                                                                        }
                                                                                                        else
                                                                                                        {
                                                                                                            <span class="text-muted">Not started</span>
                                                                                                        }
                                                                                                    }
                                                                                                    catch 
                                                                                                    {
                                                                                                        <span class="text-muted">Not started</span>
                                                                                                    }
                                                                                                }
                                                                                            </div>
                                                                                        </div>
                                                                                        
                                                                                        <!-- Completion Stage -->
                                                                                        <div class="progress-step-container">
                                                                                            <div class="progress-circle @(GetStepComplete(record, 4) ? "completed" : GetStepActive(record, 4) ? "active" : "")"
                                                                                                 data-bs-toggle="tooltip" data-bs-html="true" title="@GetCompletionTooltip(record)">
                                                                                                <i class="bi bi-award"></i>
                                                                                                @if (GetStepComplete(record, 4))
                                                                                                {
                                                                                                    <span class="check-icon"><i class="bi bi-check"></i></span>
                                                                                                }
                                                                                            </div>
                                                                                            <div class="progress-label">Completion</div>
                                                                                            <div class="progress-date">
                                                                                                @{
                                                                                                    try 
                                                                                                    {
                                                                                                        if (record.WorkCompleteDate != null && record.WorkCompleteDate != DateTime.MinValue)
                                                                                                        {
                                                                                                            @record.WorkCompleteDate.ToString("dd/MM/yyyy")
                                                                                                        }
                                                                                                        else
                                                                                                        {
                                                                                                            <span class="text-muted">Not completed</span>
                                                                                                        }
                                                                                                    }
                                                                                                    catch 
                                                                                                    {
                                                                                                        <span class="text-muted">Not completed</span>
                                                                                                    }
                                                                                                }
                                                                                            </div>
                                                                                        </div>
                                                                                    </div>
                                                                                </div>
                                                                            </td>
                                                                        </tr>
                                                                    }
                                                                }
                                                            </tbody>
                                                        </table>
                                                    </div>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                }
                                else
                                {
                                    <!-- Keep accordion for other categories -->
                            <div class="accordion" id="@(categoryName.ToLower().Replace(" ", "-"))Accordion">
                                @foreach (var monitoring in categoryModules)
                                {
                                    if (!data.ContainsKey(monitoring.MonitoringID) || data[monitoring.MonitoringID].Keys.Count == 0)
                                    {
                                        continue;
                                    }
                                    
                                    string monitoringId = $"monitoring-{monitoring.MonitoringID}";
                                    int recordsInType = 0;
                                    foreach (var plantId in data[monitoring.MonitoringID].Keys)
                                    {
                                        recordsInType += data[monitoring.MonitoringID][plantId].Count;
                                    }
                                    
                                    <div class="accordion-item border-0 border-bottom monitoring-item">
                                        <h2 class="accordion-header" id="heading-@monitoringId">
                                            <button class="accordion-button collapsed py-3" type="button" data-bs-toggle="collapse" 
                                                    data-bs-target="#@monitoringId" aria-expanded="false" aria-controls="@monitoringId">
                                                <div class="d-flex justify-content-between align-items-center w-100 me-3">
                                                    <div class="d-flex flex-column">
                                                        <div class="d-flex align-items-center">
                                                            <strong class="fs-5 text-dark fw-bold">@monitoring.MonitoringName</strong>
                                                        </div>
                                                    </div>
                                                    <div class="d-flex gap-2">
                                                    </div>
                                                </div>
                                            </button>
                                        </h2>
                                        <div id="@monitoringId" class="accordion-collapse collapse" aria-labelledby="heading-@monitoringId">
                                            <div class="accordion-body p-0">
                                                <table class="table table-hover mb-0">
                                                    <thead class="table-light">
                                                        <tr>
                                                            <th class="ps-3">Plant</th>
                                                            <th>Area</th>
                                                            <th>Status</th>
                                                            <th>Expiry</th>
                                                            <th class="text-center">Actions</th>
                                                        </tr>
                                                    </thead>
                                                    <tbody>
                                                        @foreach (var plantId in data[monitoring.MonitoringID].Keys)
                                                        {
                                                            var plantFound = null as dynamic;
                                                            foreach (var p in plants)
                                                            {
                                                                if (p.Id == plantId)
                                                                {
                                                                    plantFound = p;
                                                                    break;
                                                                }
                                                            }
                                                                        
                                                            if (plantFound == null) { continue; }
                                                            
                                                            foreach (var record in data[monitoring.MonitoringID][plantId])
                                                            {
                                                                <tr>
                                                                    <td class="ps-3">
                                                                        <span class="fw-medium">@plantFound.PlantName</span>
                                                                    </td>
                                                                    <td>
                                                                        @if (!string.IsNullOrEmpty(record.Area))
                                                                        {
                                                                            <span class="badge bg-light text-dark">@record.Area</span>
                                                                        }
                                                                        else
                                                                        {
                                                                            <span class="text-muted">-</span>
                                                                        }
                                                                    </td>
                                                                    <td>
                                                                        <span class="badge @(record.ProcStatus == "Not Started" ? "bg-secondary" : record.ProcStatusCssClass) text-white" 
                                                                              data-bs-toggle="tooltip" data-bs-html="true" title="@GetStatusTooltip(record)">
                                                                            @record.ProcStatus
                                                                        </span>
                                                                    </td>
                                                                    <td>
                                                                        <span class="badge @record.ExpStatusCssClass text-white" data-bs-toggle="tooltip" data-bs-html="true"
                                                                              title="@GetExpiryTooltip(record)">
                                                                            @record.ExpStatus
                                                                            @{
                                                                                try 
                                                                                {
                                                                                    if (record.ExpDate != null && record.ExpDate != DateTime.MinValue)
                                                                                    {
                                                                                        <span> - @record.ExpDate.Value.ToString("dd/MM/yyyy")</span>
                                                                                    }
                                                                                }
                                                                                catch { /* Ignore conversion errors */ }
                                                                            }
                                                                        </span>
                                                                    </td>
                                                                    <td class="text-center">
                                                                        <div class="btn-group">
                                                                            @if (!string.IsNullOrEmpty(record.Remarks))
                                                                            {
                                                                                <button type="button" class="btn btn-info btn-sm" data-bs-toggle="tooltip" data-bs-html="true" 
                                                                                        title="<strong>Remarks:</strong><br>@record.Remarks.Replace("\n", "<br>")">
                                                                                    <i class="bi bi-chat-dots"></i>
                                                                                </button>
                                                                            }
                                                                            <a href="@Url.Action("Details", new { id = record.Id })" class="btn btn-sm btn-info" title="View Details" data-bs-toggle="tooltip">
                                                                                <i class="bi bi-info-circle"></i>
                                                                            </a>
                                                                            @if (User.IsInRole("Admin") || (ViewBag.UserPlantIds != null && ViewBag.UserPlantIds.Contains(plantId)))
                                                                            {
                                                                                <a href="@Url.Action("UpdateStatus", new { id = record.Id })" class="btn btn-sm btn-primary" title="Update Status" data-bs-toggle="tooltip">
                                                                                    <i class="bi bi-pencil-square"></i>
                                                                                </a>
                                                                            }
                                                                            else
                                                                            {
                                                                                <button class="btn btn-sm btn-secondary disabled" title="You don't have access to update this plant" data-bs-toggle="tooltip">
                                                                                    <i class="bi bi-pencil-square"></i>
                                                                                </button>
                                                                            }
                                                                        </div>
                                                                    </td>
                                                                </tr>
                                                            }
                                                        }
                                                    </tbody>
                                                </table>
                                            </div>
                                        </div>
                                            </div>
                                        }
                                    </div>
                                }
                            </div>
                        </div>
                    }
                }
            }
        </div>
    </div>
</div>

