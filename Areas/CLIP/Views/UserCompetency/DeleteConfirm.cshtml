@model EHS_PORTAL.Areas.CLIP.Models.UserCompetency
@{
    ViewBag.Title = "Delete Competency";
}

<div class="container py-4">
    <div class="card shadow-sm">
        <div class="card-header bg-danger text-white">
            <h5 class="mb-0">Confirm Deletion</h5>
        </div>
        <div class="card-body">
            <div class="alert alert-warning">
                <i class="fas fa-exclamation-triangle me-2"></i>
                Are you sure you want to remove this competency assignment? This action cannot be undone.
            </div>
            
            <div class="mb-4">
                <dl class="row mb-0">
                    <dt class="col-sm-3">Module:</dt>
                    <dd class="col-sm-9">@Model.CompetencyModule.ModuleName</dd>
                    
                    <dt class="col-sm-3">User:</dt>
                    <dd class="col-sm-9">@Model.User.UserName</dd>
                    
                    <dt class="col-sm-3">Status:</dt>
                    <dd class="col-sm-9">
                        @switch (Model.Status)
                        {
                            case "Active":
                                <span class="badge bg-success">Active</span>
                                break;
                            case "Pending":
                                <span class="badge bg-info">Pending</span>
                                break;
                            case "Expired":
                                <span class="badge bg-danger">Expired</span>
                                break;
                            default:
                                <span class="badge bg-secondary">@Model.Status</span>
                                break;
                        }
                    </dd>
                    
                    <dt class="col-sm-3">Completion Date:</dt>
                    <dd class="col-sm-9">@(Model.CompletionDate.HasValue ? Model.CompletionDate.Value.ToShortDateString() : "-")</dd>
                    
                    <dt class="col-sm-3">Expiry Date:</dt>
                    <dd class="col-sm-9">@(Model.ExpiryDate.HasValue ? Model.ExpiryDate.Value.ToShortDateString() : "-")</dd>
                </dl>
            </div>
            
            <div class="d-flex gap-2">
                @using (Html.BeginForm("Delete", "UserCompetency", new { id = Model.Id }, FormMethod.Post))
                {
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-2"></i>Delete Permanently
                    </button>
                }
                <a href="@Url.Action("Index")" class="btn btn-outline-secondary">Cancel</a>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
} 