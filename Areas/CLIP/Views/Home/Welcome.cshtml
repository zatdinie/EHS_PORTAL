@model IEnumerable<EHS_PORTAL.Areas.CLIP.Controllers.HomeController.PlantMachineCount>
@{
    ViewBag.Title = "Welcome to CLIP";
}

<div class="jumbotron text-center py-5 bg-light">
    <h1 class="display-4">Welcome to CLIP</h1>
    <h3 class="text-muted">Competency, Licensing and Important Permit Management System</h3>
</div>

<div class="container mt-5">

        <!-- Plant Monitoring Section -->
    <h1 class="text-center mb-4 mt-5">PLANT MONITORING & PERMIT</h1>
    
    <!-- 1. Status Overview Statistics -->
    <div class="row mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Total Records</div>
                            <div class="display-3 fw-bold">@ViewBag.PlantMonitoringSummary.TotalRecords</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-clipboard-data"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-success text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Completed</div>
                            <div class="display-3 fw-bold">@ViewBag.PlantMonitoringSummary.CompletedCount</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-check-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-secondary text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">In Progress</div>
                            <div class="display-3 fw-bold">@ViewBag.PlantMonitoringSummary.InProgressCount</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-danger text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Expired</div>
                            <div class="display-3 fw-bold">@ViewBag.PlantMonitoringSummary.ExpiredCount</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-exclamation-triangle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <!-- 4. Timeline and Expiry Information -->
        <div class="col-xl-12 mb-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <i class="bi bi-calendar-event me-1"></i>
                    Upcoming Expiries - Trend
                </div>
                <div class="card-body">
                    <canvas id="expiryTimelineChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <!-- 8. Work Assignment Metrics -->
        <div class="col-xl-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <i class="bi bi-people-fill me-1"></i>
                    Work Assignments by User
                </div>
                <div class="card-body">
                    <canvas id="workAssignmentChart" height="300"></canvas>
                </div>
            </div>
        </div>
        
        <!-- Phase Distribution Chart -->
        <div class="col-xl-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <i class="bi bi-diagram-3-fill me-1"></i>
                    Monitoring Phase Distribution
                </div>
                <div class="card-body">
                    <canvas id="phaseDistributionChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

        <!-- Competency Summary Section -->
    <h1 class="text-center mb-4 mt-5">COMPETENCY MODULES</h1>
    <div class="row mb-4">
        <!-- Competency Stats Cards -->
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Total Modules</div>
                            <div class="display-3 fw-bold">@ViewBag.CompetencySummary.TotalModules</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-journal-bookmark"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-success text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Active Competencies</div>
                            <div class="display-3 fw-bold">@ViewBag.CompetencySummary.ActiveCompetencies</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-check-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-secondary text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Pending Competencies</div>
                            <div class="display-3 fw-bold">@ViewBag.CompetencySummary.PendingCompetencies</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-danger text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Expired Competencies</div>
                            <div class="display-3 fw-bold">@ViewBag.CompetencySummary.ExpiredCompetencies</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-exclamation-triangle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <div class="row">
        <!-- Competency Type Distribution Chart -->
        <div class="col-xl-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <i class="bi bi-pie-chart-fill me-1"></i>
                    Competency Type Distribution
                </div>
                <div class="card-body">
                    <canvas id="competencyTypeChart" height="300"></canvas>
                </div>
            </div>
        </div>
        
        <!-- Competency Status Chart -->
        <div class="col-xl-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <i class="bi bi-bar-chart-fill me-1"></i>
                    Competency Status Overview
                </div>
                <div class="card-body">
                    <canvas id="competencyStatusChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>
    <br/>
    <br/>
    <br/>
    <br/>
    <h1 class="text-center mb-4">CERTIFICATE OF FITNESS</h1>

    <!-- Certificate of Fitness Summary Section -->
    <div class="row mb-4">
        <!-- Certificate Stats Cards -->
        <div class="col-xl-3 col-md-6">
            <div class="card bg-primary text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Total Certificates</div>
                            <div class="display-3 fw-bold">@Model.Sum(m => m.MachineCount)</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-file-earmark-check"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-success text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Active</div>
                            <div class="display-3 fw-bold">@Model.Sum(m => m.ActiveCount)</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-check-circle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-secondary text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Expiring Soon</div>
                            <div class="display-3 fw-bold">@Model.Sum(m => m.ExpiringSoonCount)</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-hourglass-split"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        
        <div class="col-xl-3 col-md-6">
            <div class="card bg-danger text-white mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center">
                        <div>
                            <div class="fs-5 text-white">Expired</div>
                            <div class="display-3 fw-bold">@Model.Sum(m => m.ExpiredCount)</div>
                        </div>
                        <div class="fs-1">
                            <i class="bi bi-exclamation-triangle"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="row">
        <div class="col-xl-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <i class="bi bi-bar-chart-fill me-1"></i>
                    Machine Count by Plant
                </div>
                <div class="card-body">
                    <canvas id="plantMachineChart" height="300"></canvas>
                </div>
            </div>
        </div>

        <div class="col-xl-6 mb-4">
            <div class="card shadow-sm">
                <div class="card-header">
                    <i class="bi bi-pie-chart-fill me-1"></i>
                    Machine Status Distribution
                </div>
                <div class="card-body">
                    <canvas id="statusPieChart" height="300"></canvas>
                </div>
            </div>
        </div>
    </div>
    
    
    


<div class="row mt-4 mb-5">
        <div class="col-md-6 offset-md-3 text-center">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="card-title">Get Started</h2>
                    <p class="card-text">
                        Please log in to access the system.
                    </p>
                    <div class="d-grid gap-2 col-8 mx-auto mt-4">
                        @Html.ActionLink("Log in", "Login", "Account", null, new { @class = "btn btn-primary btn-lg mb-3" })
                    </div>
                </div>
            </div>
        </div>
    </div>

@section scripts {
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"
        integrity="sha512-fD9DI5bZwQxOi7MhYWnnNPlvXdp/2Pj3XSTRrFs5FQa4mizyGLnJcN6tuvUS6LbmgN1ut+XGSABKvjN0H6Aoow=="
        crossorigin="anonymous" referrerpolicy="no-referrer"></script>

    <script>
        // Register ChartDataLabels plugin
        Chart.register(ChartDataLabels);

        // Data from the model - original unordered data
        var originalPlantNames = [@Html.Raw(string.Join(",", Model.Select(m => "'" + m.PlantName + "'")))];
        var originalMachineCounts = [@string.Join(",", Model.Select(m => m.MachineCount))];
        var originalActiveData = [@string.Join(",", Model.Select(m => m.ActiveCount))];
        var originalExpiringSoonData = [@string.Join(",", Model.Select(m => m.ExpiringSoonCount))];
        var originalExpiredData = [@string.Join(",", Model.Select(m => m.ExpiredCount))];

        // Define custom order
        var customOrder = ["Plant 1", "Plant 3", "Plant 5", "Plant 13", "Plant 55", "Plant 21", "Plant 34"];

        // Reorder data according to custom order
        var plantNames = [];
        var machineCounts = [];
        var activeData = [];
        var expiringSoonData = [];
        var expiredData = [];

        // Map original data to the custom order
        customOrder.forEach(function (plantName) {
            var index = originalPlantNames.indexOf(plantName);
            if (index !== -1) {
                plantNames.push(originalPlantNames[index]);
                machineCounts.push(originalMachineCounts[index]);
                activeData.push(originalActiveData[index]);
                expiringSoonData.push(originalExpiringSoonData[index]);
                expiredData.push(originalExpiredData[index]);
            }
        });

        // Total counts for the pie chart
        var totalActive = @Model.Sum(m => m.ActiveCount);
        var totalExpiringSoon = @Model.Sum(m => m.ExpiringSoonCount);
        var totalExpired = @Model.Sum(m => m.ExpiredCount);

        // Set up chart colors
        var activeColor = 'rgba(40, 167, 69, 0.7)';
        var expiringSoonColor = 'rgba(255, 193, 7, 0.7)';
        var expiredColor = 'rgba(220, 53, 69, 0.7)';

        // Create bar chart showing machine counts by plant
        var plantMachineCtx = document.getElementById('plantMachineChart').getContext('2d');
        var plantMachineChart = new Chart(plantMachineCtx, {
            type: 'bar',
            data: {
                labels: plantNames,
                datasets: [
                    {
                        label: 'Active',
                        data: activeData,
                        backgroundColor: activeColor,
                        borderColor: 'rgba(40, 167, 69, 1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Expiring Soon',
                        data: expiringSoonData,
                        backgroundColor: expiringSoonColor,
                        borderColor: 'rgba(255, 193, 7, 1)',
                        borderWidth: 1
                    },
                    {
                        label: 'Expired',
                        data: expiredData,
                        backgroundColor: expiredColor,
                        borderColor: 'rgba(220, 53, 69, 1)',
                        borderWidth: 1
                    }
                ]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    x: {
                        stacked: true,
                    },
                    y: {
                        stacked: true,
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1,
                            precision: 0
                        }
                    }
                },
                plugins: {
                    title: {
                        display: true,
                        text: 'Certificate of Fitness by Plant'
                    },
                    legend: {
                        position: 'bottom'
                    },
                    tooltip: {
                        callbacks: {
                            footer: function (tooltipItems) {
                                let total = 0;
                                tooltipItems.forEach(function (tooltipItem) {
                                    const index = tooltipItem.dataIndex;
                                    // Get value from all datasets for this index
                                    plantMachineChart.data.datasets.forEach(function (dataset) {
                                        total += dataset.data[index] || 0;
                                    });
                                });
                                return 'Total: ' + total;
                            }
                        }
                    },
                    datalabels: {
                        color: '#6E6E6E',
                        font: {
                            weight: 'bold'
                        },
                        formatter: function (value, context) {
                            // Only show labels for the last dataset in stack
                            if (context.datasetIndex !== context.chart.data.datasets.length - 1) {
                                return null;
                            }

                            // Calculate total from all datasets for this index
                            const index = context.dataIndex;
                            let total = 0;
                            context.chart.data.datasets.forEach(function (dataset) {
                                total += dataset.data[index] || 0;
                            });
                            return total;
                        },
                        anchor: 'end',
                        align: 'top',
                        offset: 0
                    }
                }
            }
        });

        // Create pie chart showing status distribution
        var statusPieCtx = document.getElementById('statusPieChart').getContext('2d');
        var statusPieChart = new Chart(statusPieCtx, {
            type: 'pie',
            data: {
                labels: ['Active', 'Expiring Soon', 'Expired'],
                datasets: [{
                    data: [totalActive, totalExpiringSoon, totalExpired],
                    backgroundColor: [activeColor, expiringSoonColor, expiredColor],
                    borderColor: ['rgba(40, 167, 69, 1)', 'rgba(255, 193, 7, 1)', 'rgba(220, 53, 69, 1)'],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    },
                    title: {
                        display: true,
                        text: 'Certificate of Fitness Status Distribution'
                    },
                    datalabels: {
                        color: '#fff',
                        font: {
                            weight: 'bold'
                        },
                        formatter: function (value, context) {
                            return value > 0 ? value : '';
                        }
                    }
                }
            }
        });
        
        // Competency Type Distribution Chart
        var competencyTypeLabels = [];
        var competencyTypeData = [];
        var competencyTypeColors = [
            'rgba(40, 167, 69, 0.7)',  // Green for Environment
            'rgba(255, 193, 7, 0.7)',  // Yellow for Safety
            'rgba(13, 110, 253, 0.7)', // Blue for Other
            'rgba(108, 117, 125, 0.7)' // Gray for any additional types
        ];
        
        @foreach (var type in ViewBag.CompetencySummary.CompetencyTypeCount)
        {
            @:competencyTypeLabels.push('@type.Key');
            @:competencyTypeData.push(@type.Value);
        }
        
        var competencyTypeCtx = document.getElementById('competencyTypeChart').getContext('2d');
        var competencyTypeChart = new Chart(competencyTypeCtx, {
            type: 'pie',
            data: {
                labels: competencyTypeLabels,
                datasets: [{
                    data: competencyTypeData,
                    backgroundColor: competencyTypeColors.slice(0, competencyTypeLabels.length),
                    borderColor: competencyTypeColors.map(color => color.replace('0.7', '1')),
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    },
                    title: {
                        display: true,
                        text: 'Competency Distribution by Type'
                    },
                    datalabels: {
                        color: '#000',
                        font: {
                            weight: 'bold'
                        },
                        formatter: function (value, context) {
                            return value > 0 ? value : '';
                        }
                    }
                }
            }
        });
        
        // Competency Status Chart
        var competencyStatusCtx = document.getElementById('competencyStatusChart').getContext('2d');
        var competencyStatusChart = new Chart(competencyStatusCtx, {
            type: 'bar',
            data: {
                labels: ['Active', 'Pending', 'Expired'],
                datasets: [{
                    label: 'Competencies',
                    data: [
                        @ViewBag.CompetencySummary.ActiveCompetencies,
                        @ViewBag.CompetencySummary.PendingCompetencies,
                        @ViewBag.CompetencySummary.ExpiredCompetencies
                    ],
                    backgroundColor: [
                        'rgba(40, 167, 69, 0.7)',
                        'rgba(255, 193, 7, 0.7)',
                        'rgba(220, 53, 69, 0.7)'
                    ],
                    borderColor: [
                        'rgba(40, 167, 69, 1)',
                        'rgba(255, 193, 7, 1)',
                        'rgba(220, 53, 69, 1)'
                    ],
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1,
                            precision: 0
                        }
                    }
                },
                plugins: {
                    title: {
                        display: true,
                        text: 'Competency Status Overview'
                    },
                    legend: {
                        display: false
                    },
                    datalabels: {
                        color: '#000',
                        font: {
                            weight: 'bold'
                        },
                        anchor: 'end',
                        align: 'top',
                        offset: 0
                    }
                }
            }
        });
        
        // Plant Monitoring Charts
        
        // Expiry Timeline Chart
        var expiryLabels = [];
        var expiryData = [];
        var expiryColors = [];
        
        @foreach (var item in ViewBag.PlantMonitoringSummary.ExpiryTimeline)
        {
            @:expiryLabels.push('@item.Month');
            @:expiryData.push(@item.Count);
            
            // Different colors based on urgency
            if (item.IsCurrentMonth) {
                @:expiryColors.push('rgba(220, 53, 69, 0.7)'); // Red for current month
            } else if (item.IsNextMonth) {
                @:expiryColors.push('rgba(255, 193, 7, 0.7)'); // Yellow for next month
            } else {
                @:expiryColors.push('rgba(13, 110, 253, 0.7)'); // Blue for future months
            }
        }
        
        var expiryCtx = document.getElementById('expiryTimelineChart').getContext('2d');
        var expiryChart = new Chart(expiryCtx, {
            type: 'line',
            data: {
                labels: expiryLabels,
                datasets: [{
                    label: 'Expiring Items',
                    data: expiryData,
                    backgroundColor: 'rgba(13, 110, 253, 0.1)',
                    borderColor: 'rgba(13, 110, 253, 0.8)',
                    borderWidth: 3,
                    tension: 0.3,
                    fill: true,
                    pointBackgroundColor: expiryColors,
                    pointBorderColor: expiryColors.map(color => color.replace('0.7', '1')),
                    pointRadius: 6,
                    pointHoverRadius: 8
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1,
                            precision: 0
                        },
                        title: {
                            display: true,
                            text: 'Number of Expiring Items',
                            font: {
                                size: 14,
                                weight: 'bold'
                            }
                        }
                    },
                    x: {
                        title: {
                            display: true,
                            text: 'Month',
                            font: {
                                size: 14,
                                weight: 'bold'
                            }
                        }
                    }
                },
                plugins: {
                    title: {
                        display: true,
                        text: 'Upcoming Expiries by Month',
                        font: {
                            size: 18,
                            weight: 'bold'
                        },
                        padding: {
                            top: 10,
                            bottom: 20
                        }
                    },
                    legend: {
                        display: true,
                        position: 'top'
                    },
                    tooltip: {
                        callbacks: {
                            title: function(tooltipItems) {
                                return tooltipItems[0].label;
                            },
                            label: function(context) {
                                let label = context.dataset.label || '';
                                if (label) {
                                    label += ': ';
                                }
                                if (context.parsed.y !== null) {
                                    label += context.parsed.y + ' items';
                                }
                                return label;
                            },
                            afterLabel: function(context) {
                                const index = context.dataIndex;
                                if (index === 0) {
                                    return 'Current month - urgent attention required';
                                } else if (index === 1) {
                                    return 'Next month - plan ahead';
                                }
                                return '';
                            }
                        }
                    },
                    datalabels: {
                        color: function(context) {
                            return context.dataIndex <= 1 ? '#000' : '#666';
                        },
                        font: {
                            weight: 'bold',
                            size: function(context) {
                                return context.dataIndex <= 1 ? 14 : 12;
                            }
                        },
                        formatter: function(value, context) {
                            return value > 0 ? value : '';
                        },
                        anchor: 'end',
                        align: 'top',
                        offset: 5
                    }
                }
            }
        });
        
        // Work Assignment Chart
        var assigneeLabels = [];
        var assignmentData = [];
        var assignmentColors = [
            'rgba(40, 167, 69, 0.7)',  // Green
            'rgba(255, 193, 7, 0.7)',  // Yellow
            'rgba(13, 110, 253, 0.7)', // Blue
            'rgba(108, 117, 125, 0.7)', // Gray
            'rgba(111, 66, 193, 0.7)',  // Purple
            'rgba(23, 162, 184, 0.7)',  // Cyan
            'rgba(253, 126, 20, 0.7)'   // Orange
        ];
        
        @foreach (var item in ViewBag.PlantMonitoringSummary.WorkAssignments)
        {
            @:assigneeLabels.push('@item.UserName');
            @:assignmentData.push(@item.Count);
        }
        
        var assignmentCtx = document.getElementById('workAssignmentChart').getContext('2d');
        var assignmentChart = new Chart(assignmentCtx, {
            type: 'pie',
            data: {
                labels: assigneeLabels,
                datasets: [{
                    data: assignmentData,
                    backgroundColor: assignmentColors.slice(0, assigneeLabels.length),
                    borderColor: assignmentColors.map(color => color.replace('0.7', '1')).slice(0, assigneeLabels.length),
                    borderWidth: 1
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: {
                        position: 'bottom'
                    },
                    title: {
                        display: true,
                        text: 'Work Assignments by User'
                    },
                    datalabels: {
                        color: '#000',
                        font: {
                            weight: 'bold'
                        },
                        formatter: function(value, context) {
                            return value > 0 ? value : '';
                        }
                    }
                }
            }
        });
        
        // Phase Distribution Chart
        var phaseLabels = [];
        var phaseData = [];
        var phaseColors = [
            'rgba(255, 193, 7, 0.7)',  // Yellow for Quotation
            'rgba(13, 110, 253, 0.7)', // Blue for ePR
            'rgba(111, 66, 193, 0.7)',  // Purple for Work Execution
            'rgba(40, 167, 69, 0.7)',  // Green for Completed
            'rgba(108, 117, 125, 0.7)' // Gray for Not Started
        ];
        
        @foreach (var phase in ViewBag.PlantMonitoringSummary.PhaseDistribution)
        {
            @:phaseLabels.push('@phase.Key');
            @:phaseData.push(@phase.Value);
        }
        
        var phaseCtx = document.getElementById('phaseDistributionChart').getContext('2d');
        var phaseChart = new Chart(phaseCtx, {
            type: 'bar',
            data: {
                labels: phaseLabels,
                datasets: [{
                    label: 'Records',
                    data: phaseData,
                    backgroundColor: phaseColors,
                    borderColor: phaseColors.map(color => color.replace('0.7', '1')),
                    borderWidth: 1,
                    borderRadius: 4,
                    barPercentage: 0.6
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            stepSize: 1,
                            precision: 0
                        }
                    }
                },
                plugins: {
                    title: {
                        display: true,
                        text: 'Monitoring Records by Phase'
                    },
                    legend: {
                        display: false
                    },
                    datalabels: {
                        color: '#000',
                        font: {
                            weight: 'bold'
                        },
                        anchor: 'end',
                        align: 'top',
                        offset: 0
                    }
                }
            }
        });
    </script>
}