@model IEnumerable<EHS_PORTAL.Areas.CLIP.Models.ActivityTraining>

@{
    ViewBag.Title = "Training Activities";
    Layout = "~/Areas/CLIP/Views/Shared/_Layout.cshtml";
}

<h1>My Training Activities</h1>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-check-circle me-2"></i> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show mb-3" role="alert">
        <i class="bi bi-exclamation-circle me-2"></i> @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="d-flex justify-content-end mb-3">
    <a href="@Url.Action("Create")" class="btn btn-primary">
        <i class="bi bi-plus-circle"></i> Log New Activity
    </a>
</div>

<div class="table-responsive">
    <table class="table table-hover">
        <thead class="bg-light">
            <tr>
                <th>Activity Name</th>
                <th>Date</th>
                <th>ATOM CEP Points</th>
                <th>DOE CPD Points</th>
                <th>DOSH CEP Points</th>
                <th>Document</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (!Model.Any())
            {
                <tr>
                    <td colspan="6" class="text-center py-4">
                        <i class="bi bi-info-circle text-info fs-4 d-block mb-2"></i>
                        <p>No training activities found.</p>
                        <a href="@Url.Action("Create")" class="btn btn-primary btn-sm mt-2">
                            <i class="bi bi-plus-circle"></i> Log New Activity
                        </a>
                    </td>
                </tr>
            }
            else
            {
                foreach (var activity in Model)
                {
                    <tr>
                        <td>@activity.ActivityName</td>
                        <td>@activity.ActivityDate.ToString("MM/dd/yyyy")</td>
                        <td>@(activity.ATOM_CEP_Points.HasValue ? activity.ATOM_CEP_Points.Value.ToString() : "-")</td>
                        <td>@(activity.DOE_CPD_Points.HasValue ? activity.DOE_CPD_Points.Value.ToString() : "-")</td>
                        <td>@(activity.DOSH_CEP_Points.HasValue ? activity.DOSH_CEP_Points.Value.ToString() : "-")</td>
                        <td>
                            @if (!string.IsNullOrEmpty(activity.Document))
                            {
                                <a href="@Url.Action("DownloadDocument", new { id = activity.Id })" class="btn btn-sm btn-outline-primary" title="Download Document">
                                    <i class="bi bi-file-earmark"></i>
                                </a>
                            }
                        </td>
                        <td>
                            <div class="btn-group">
                                <a href="@Url.Action("Details", new { id = activity.Id })" class="btn btn-info btn-sm" data-bs-toggle="tooltip" data-bs-placement="top" title="Details">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                <a href="@Url.Action("Edit", new { id = activity.Id })" class="btn btn-warning btn-sm" data-bs-toggle="tooltip" data-bs-placement="top" title="Edit">
                                    <i class="bi bi-pencil-square"></i>
                                </a>
                                <button type="button" class="btn btn-danger btn-sm" data-bs-toggle="tooltip" data-bs-placement="top" title="Delete" 
                                        onclick="$('#deleteModal@(activity.Id)').modal('show')">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </div>
                            
                            <!-- Delete Confirmation Modal -->
                            <div class="modal fade" id="deleteModal@(activity.Id)" tabindex="-1" aria-labelledby="deleteModalLabel@(activity.Id)" aria-hidden="true">
                                <div class="modal-dialog modal-sm">
                                    <div class="modal-content">
                                        <div class="modal-header">
                                            <h5 class="modal-title" id="deleteModalLabel@(activity.Id)">Confirm Delete</h5>
                                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                        </div>
                                        <div class="modal-body">
                                            Are you sure you want to delete this activity?
                                        </div>
                                        <div class="modal-footer">
                                            @using (Html.BeginForm("Delete", "ActivityTraining", new { id = activity.Id }, FormMethod.Post))
                                            {
                                                @Html.AntiForgeryToken()
                                                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                                <button type="submit" class="btn btn-danger">Delete</button>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Initialize tooltips
            var tooltipTriggerList = [].slice.call(document.querySelectorAll('[data-bs-toggle="tooltip"]'))
            var tooltipList = tooltipTriggerList.map(function (tooltipTriggerEl) {
                return new bootstrap.Tooltip(tooltipTriggerEl)
            });
            
            $('table').DataTable({
                "order": [[1, "desc"]]
            });
        });
    </script>
} 