@model EHS_PORTAL.Areas.CLIP.Models.IndexViewModel
@{
    ViewBag.Title = "My Profile";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>My Profile</h1>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            @TempData["ErrorMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">User Details</h5>
                </div>
                <div class="card-body">
                    <dl class="mb-0">
                        <dt>Username</dt>
                        <dd>@Model.UserName</dd>
                        
                        <dt>Employee ID</dt>
                        <dd>@(string.IsNullOrEmpty(Model.EmpID) ? "Not set" : Model.EmpID)</dd>
                        
                        <dt>Email</dt>
                        <dd>@Model.Email</dd>
                        
                        <dt>Phone Number</dt>
                        <dd>@(string.IsNullOrEmpty(Model.PhoneNumber) ? "Not set" : Model.PhoneNumber)</dd>
                    </dl>
                </div>
                <div class="card-footer bg-light">
                    <a href="@Url.Action("EditProfile", "Manage")" class="btn btn-primary">
                        <i class="fas fa-edit me-2"></i>Edit Profile
                    </a>
                </div>
            </div>
        </div>
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Professional Development Points</h5>
                </div>
                <div class="card-body">
                    <div class="row text-center">
                        <div class="col-md-4">
                            <div class="d-flex flex-column align-items-center">
                                <i class="fas fa-leaf mb-2 text-success" style="font-size: 1.5rem;"></i>
                                <div class="display-4 text-success">@(Model.DOE_CPD ?? 0)</div>
                                <span>DOE CPD</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex flex-column align-items-center">
                                <i class="fas fa-hard-hat mb-2 text-warning" style="font-size: 1.5rem;"></i>
                                <div class="display-4 text-warning">@(Model.Dosh_CEP ?? 0)</div>
                                <span>DOSH CEP</span>
                            </div>
                        </div>
                        <div class="col-md-4">
                            <div class="d-flex flex-column align-items-center">
                                <i class="fas fa-atom mb-2 text-primary" style="font-size: 1.5rem;"></i>
                                <div class="display-4 text-primary">@(Model.Atom_CEP ?? 0)</div>
                                <span>ATOM CEP</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">Account Summary</h5>
                </div>
                <div class="card-body">
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <i class="fas fa-shield-alt mb-2 text-primary" style="font-size: 1.5rem;"></i>
                                    <h5>Security</h5>
                                    <a href="@Url.Action("ChangePassword", "Manage")" class="btn btn-outline-primary btn-sm mt-2">
                                        Change Password
                                    </a>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="card bg-light">
                                <div class="card-body text-center">
                                    <i class="fas fa-clipboard-check mb-2 text-success" style="font-size: 1.5rem;"></i>
                                    <h5>Competencies</h5>
                                    <a href="@Url.Action("MyCompetencies", "UserCompetency")" class="btn btn-outline-success btn-sm mt-2">
                                        View My Competencies
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
}
