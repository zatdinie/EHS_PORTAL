@model EHS_PORTAL.Areas.CLIP.Models.ChangePasswordViewModel
@{
    ViewBag.Title = "Change Password";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="card-title mb-0">Change Password</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("ChangePassword", "Manage", FormMethod.Post, new { @class = "needs-validation", role = "form", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.ValidationSummary("", new { @class = "text-danger" })

                        <div class="mb-3">
                            <label for="OldPassword" class="form-label"><strong>Current Password</strong></label>
                            <div class="input-group">
                                @Html.PasswordFor(m => m.OldPassword, new { @class = "form-control", required = "required" })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter your current password">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(m => m.OldPassword, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="NewPassword" class="form-label"><strong>New Password</strong></label>
                            <div class="input-group">
                                @Html.PasswordFor(m => m.NewPassword, new { @class = "form-control", required = "required" })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter your new password">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(m => m.NewPassword, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="ConfirmPassword" class="form-label"><strong>Confirm New Password</strong></label>
                            <div class="input-group">
                                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control", required = "required" })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Confirm your new password">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(m => m.ConfirmPassword, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mt-4 d-flex justify-content-between">
                            <a href="@Url.Action("Index", "Home")" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to Home
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-key me-2"></i>Change Password
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script>
        $(function () {
            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();
            
            // Bootstrap form validation
            (function () {
                'use strict'
                var forms = document.querySelectorAll('.needs-validation')
                Array.prototype.slice.call(forms)
                    .forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
            })()
        });
    </script>
}