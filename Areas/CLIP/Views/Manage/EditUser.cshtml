@model EHS_PORTAL.Areas.CLIP.Models.EditUserProfileViewModel
@{
    ViewBag.Title = "Edit User Profile";
}

<div class="container">
    <div class="row mb-4">
        <div class="col-md-12">
            <br></br>
            <div class="card">
                <div class="card-header bg-secondary text-white">
                    <h4 class="mb-0"><i class="fas fa-user-edit me-2"></i>Edit User Profile</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("EditUser", "Manage", FormMethod.Post, new { @class = "needs-validation" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(m => m.Id)
                        
                        @Html.ValidationSummary(true, "", new { @class = "text-danger mb-3" })
                        
                        <div class="row">
                            <!-- Basic Information -->
                            <div class="col-md-6">
                                <h5 class="border-bottom pb-2 mb-3">Basic Information</h5>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.UserName, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(m => m.UserName, new { @class = "form-control" })
                                        <span class="input-group-text" data-bs-toggle="tooltip" title="User's login name">
                                            <i class="bi bi-info-circle"></i>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.UserName, "", new { @class = "text-danger" })
                                </div>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.Email, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(m => m.Email, new { @class = "form-control" })
                                        <span class="input-group-text" data-bs-toggle="tooltip" title="User's email address">
                                            <i class="bi bi-info-circle"></i>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.Email, "", new { @class = "text-danger" })
                                </div>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.EmpID, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(m => m.EmpID, new { @class = "form-control" })
                                        <span class="input-group-text" data-bs-toggle="tooltip" title="Employee ID number">
                                            <i class="bi bi-info-circle"></i>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.EmpID, "", new { @class = "text-danger" })
                                </div>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.PhoneNumber, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(m => m.PhoneNumber, new { @class = "form-control" })
                                        <span class="input-group-text" data-bs-toggle="tooltip" title="User's contact phone number">
                                            <i class="bi bi-info-circle"></i>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.PhoneNumber, "", new { @class = "text-danger" })
                                </div>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.Role, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        @Html.DropDownListFor(m => m.Role, Model.RolesList, "-- Select Role --", new { @class = "form-select" })
                                        <span class="input-group-text" data-bs-toggle="tooltip" title="User's system role and permissions">
                                            <i class="bi bi-info-circle"></i>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.Role, "", new { @class = "text-danger" })
                                </div>
                            </div>
                            
                            <!-- Additional Information -->
                            <div class="col-md-6">
                                <h5 class="border-bottom pb-2 mb-3">Additional Information</h5>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.Atom_CEP, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(m => m.Atom_CEP, new { @class = "form-control", type = "number" })
                                        <span class="input-group-text" data-bs-toggle="tooltip" title="Atomic Energy Licensing Board Certification">
                                            <i class="bi bi-info-circle"></i>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.Atom_CEP, "", new { @class = "text-danger" })
                                </div>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.DOE_CPD, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(m => m.DOE_CPD, new { @class = "form-control", type = "number" })
                                        <span class="input-group-text" data-bs-toggle="tooltip" title="Department of Environment Certification">
                                            <i class="bi bi-info-circle"></i>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.DOE_CPD, "", new { @class = "text-danger" })
                                </div>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.Dosh_CEP, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        @Html.TextBoxFor(m => m.Dosh_CEP, new { @class = "form-control", type = "number" })
                                        <span class="input-group-text" data-bs-toggle="tooltip" title="Department of Occupational Safety and Health Certification">
                                            <i class="bi bi-info-circle"></i>
                                        </span>
                                    </div>
                                    @Html.ValidationMessageFor(m => m.Dosh_CEP, "", new { @class = "text-danger" })
                                </div>
                            </div>
                        </div>
                        
                        <!-- Plants Assignment -->
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <h5 class="border-bottom pb-2 mb-3">Plant Assignments</h5>
                                
                                <div class="mb-3">
                                    @Html.LabelFor(m => m.SelectedPlantIds, new { @class = "form-label fw-bold" })
                                    <div class="input-group">
                                        <div class="card w-100">
                                            <div class="card-body">
                                                <div class="row">
                                                    @foreach (var plant in Model.PlantsList)
                                                    {
                                                        <div class="col-md-4 mb-2">
                                                            <div class="form-check">
                                                                <input type="checkbox" 
                                                                       name="SelectedPlantIds" 
                                                                       value="@plant.Value" 
                                                                       id="plant_@plant.Value" 
                                                                       class="form-check-input"
                                                                       @(plant.Selected ? "checked" : "") />
                                                                <label class="form-check-label" for="plant_@plant.Value">@plant.Text</label>
                                                            </div>
                                                        </div>
                                                    }
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Submit Buttons -->
                        <div class="row mt-4">
                            <div class="col-md-12">
                                <button type="submit" name="section" value="all" class="btn btn-primary">
                                    <i class="fas fa-save me-1"></i>Save All Changes
                                </button>
                                <a href="@Url.Action("Users", "Manage")" class="btn btn-secondary ms-2">
                                    <i class="fas fa-times me-1"></i>Cancel
                                </a>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script>
        $(document).ready(function () {
            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();
        });
    </script>
} 