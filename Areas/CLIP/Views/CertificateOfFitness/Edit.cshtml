@model EHS_PORTAL.Areas.CLIP.Models.CertificateOfFitness

@{
    ViewBag.Title = "Edit Certificate of Fitness";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="card-title mb-0">Edit Certificate of Fitness</h4>
                </div>
                <div class="card-body">
                    @if (TempData["ErrorMessage"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            @TempData["ErrorMessage"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @using (Html.BeginForm("Edit", "CertificateOfFitness", FormMethod.Post, new { @class = "needs-validation", enctype = "multipart/form-data", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()
                        @Html.HiddenFor(model => model.Id)
                        @Html.HiddenFor(model => model.DocumentPath)
                        @Html.HiddenFor(model => model.Status)

                        <div class="mb-3">
                            <label for="PlantId" class="form-label"><strong>Plant</strong></label>
                            <div class="input-group">
                                @Html.DropDownList("PlantId", null, new { @class = "form-select", required = "required" })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Select the plant location">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.PlantId, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="RegistrationNo" class="form-label"><strong>Registration Number</strong></label>
                            <div class="input-group">
                                @Html.EditorFor(model => model.RegistrationNo, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Registration Number must be unique across all certificates">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.RegistrationNo, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="MachineName" class="form-label"><strong>Machine Name</strong></label>
                            <div class="input-group">
                                @Html.EditorFor(model => model.MachineName, new { htmlAttributes = new { @class = "form-control", required = "required" } })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter the name of the machine">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.MachineName, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="ExpiryDate" class="form-label"><strong>Expiry Date</strong></label>
                            <div class="input-group">
                                @Html.EditorFor(model => model.ExpiryDate, new { htmlAttributes = new { @class = "form-control", type = "date", required = "required" } })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Status will be updated automatically based on expiry date">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.ExpiryDate, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="Status" class="form-label"><strong>Status</strong></label>
                            <div class="input-group">
                                <select id="Status" name="Status" class="form-select">
                                    <option value="Active" @(Model.Status == "Active" ? "selected" : "")>Active</option>
                                    <option value="Expired" @(Model.Status == "Expired" ? "selected" : "")>Expired</option>
                                    <option value="Expiring Soon" @(Model.Status == "Expiring Soon" ? "selected" : "")>Expiring Soon</option>
                                </select>
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Select the status of the certificate">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            <small class="text-muted">Select the appropriate status based on certificate validity</small>
                        </div>

                        <div class="mb-3">
                            <label for="Location" class="form-label"><strong>Location</strong></label>
                            <div class="input-group">
                                @Html.EditorFor(model => model.Location, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter current location of the machine" } })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Physical location where the machine is placed">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.Location, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="Department" class="form-label"><strong>Department</strong></label>
                            <div class="input-group">
                                @Html.EditorFor(model => model.Department, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter department name" } })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Department responsible for the machine">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.Department, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="HostInfo" class="form-label"><strong>Host Information</strong></label>
                            <div class="input-group">
                                @Html.EditorFor(model => model.HostInfo, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter original owner info" } })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="First time machine registered owner">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.HostInfo, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="ResidentInfo" class="form-label"><strong>Resident Information</strong></label>
                            <div class="input-group">
                                @Html.EditorFor(model => model.ResidentInfo, new { htmlAttributes = new { @class = "form-control", placeholder = "Enter current owner info" } })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Machine current location">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.ResidentInfo, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="Remarks" class="form-label"><strong>Remarks</strong></label>
                            <div class="input-group">
                                @Html.TextAreaFor(model => model.Remarks, new { @class = "form-control", rows = 3 })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Additional notes about this certificate">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(model => model.Remarks, "", new { @class = "invalid-feedback" })
                        </div>

                        <div class="mb-3">
                            <label for="pdfDocument" class="form-label"><strong>PDF Document</strong></label>
                            <div class="input-group">
                                <input type="file" name="pdfDocument" id="pdfDocument" class="form-control file-upload" accept=".pdf" data-max-size="20" />
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Upload a new PDF document of the certificate (Max size: 20MB)">
                                    <i class="bi bi-file-earmark"></i>
                                </span>
                            </div>
                            <small class="text-muted">Max file size: 20MB</small>
                            @if (!string.IsNullOrEmpty(Model.DocumentPath))
                            {
                                <div class="mt-2">
                                    <a href="@Url.Action("ViewDocument", "CertificateOfFitness", new { id = Model.Id })" target="_blank" class="btn btn-sm btn-info">
                                        <i class="bi bi-file-earmark-pdf"></i> View Current Document
                                    </a>
                                </div>
                            }
                        </div>

                        <div class="mt-4 d-flex justify-content-between">
                            <a href="@Url.Action("Index", "CertificateOfFitness")" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to List
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-save me-2"></i>Save Changes
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script>
        $(function () {
            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();
            
            // Bootstrap form validation
            (function () {
                'use strict'
                var forms = document.querySelectorAll('.needs-validation')
                Array.prototype.slice.call(forms)
                    .forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
            })()
            
            // File size validation
            $('.file-upload').on('change', function() {
                var fileInput = $(this)[0];
                var maxSize = parseInt($(this).data('max-size')) * 1024 * 1024; // Convert MB to bytes
                
                if (fileInput.files.length > 0) {
                    var fileSize = fileInput.files[0].size; // in bytes
                    if (fileSize > maxSize) {
                        alert('File size exceeds the limit of 20MB. Please choose a smaller file.');
                        $(this).val(''); // Clear the file input
                        return false;
                    }
                }
            });

            // Form submission validation
            $('form').on('submit', function(e) {
                var isValid = true;
                $('.file-upload').each(function() {
                    var fileInput = $(this)[0];
                    if (fileInput.files.length > 0) {
                        var maxSize = parseInt($(this).data('max-size')) * 1024 * 1024;
                        var fileSize = fileInput.files[0].size;
                        if (fileSize > maxSize) {
                            alert('File size exceeds the limit of 20MB. Please choose a smaller file.');
                            $(this).val('');
                            isValid = false;
                            return false;
                        }
                    }
                });
                
                return isValid;
            });
        });
    </script>
} 