<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="shortcut icon" href="~/Areas/CLIP/favicon.ico" type="image/x-icon" />
    <title>@ViewBag.Title - CLIP | Competency, Licensing and Important Permit</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
    <!-- Font Awesome 6.5.1 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer" />
    @Styles.Render("~/Content/css")
    @Scripts.Render("~/bundles/modernizr")
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chartjs-plugin-datalabels@2.0.0"></script>
    <style>
        .navbar-nav .nav-item, .navbar-nav > li {
            margin-right: 20px;
        }
    </style>
</head>
<body>
    <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark bg-dark">
        <div class="container">
            @if (Request.IsAuthenticated)
            {
                <div class="navbar-brand d-flex align-items-center">
                    <img src="~/Images/logo.png" alt="CLIP Logo" height="30" class="me-2" />
                    @Html.ActionLink("CLIP", "Index", "Home", new { area = "CLIP" }, new { @class = "text-decoration-none text-white" })
                </div>
            }
            else
            {
                <div class="navbar-brand d-flex align-items-center">
                    <a href="@Url.Action("Welcome", "Home", new { area = "CLIP" })">
                        <img src="~/Images/logo.png" alt="CLIP Logo" height="30" class="me-2" />
                    </a>
                    @Html.ActionLink("CLIP", "Welcome", "Home", new { area = "CLIP" }, new { @class = "text-decoration-none text-white" })
                </div>
            }
            <button type="button" class="navbar-toggler" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" title="Toggle navigation" aria-controls="navbarSupportedContent"
                    aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse d-sm-inline-flex justify-content-between">
                @if (Request.IsAuthenticated)
                {
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="monitoringDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Monitoring
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="monitoringDropdown">
                            <li>@Html.ActionLink("Plant Monitoring", "Index", "PlantMonitoring", new { area = "CLIP" }, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Progress Tracker", "Schedule", "PlantMonitoring", new { area = "CLIP" }, new { @class = "dropdown-item" })</li>
                            <li><hr class="dropdown-divider"></li>
                            <li>@Html.ActionLink("Manage Monitoring Types", "Index", "Monitoring", new { area = "CLIP" }, new { @class = "dropdown-item" })</li>
                        </ul>
                    </li>
                    <li class="nav-item dropdown">
                        <a class="nav-link dropdown-toggle" href="#" id="competencyDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                            Competency
                        </a>
                        <ul class="dropdown-menu" aria-labelledby="competencyDropdown">
                            @* <li>@Html.ActionLink("Competency Modules", "Index", "Competency", new { area = "CLIP" }, new { @class = "dropdown-item" })</li> *@
                            <li>@Html.ActionLink("Competent Person", "Index", "UserCompetency", new { area = "CLIP" }, new { @class = "dropdown-item" })</li>
                            <li><hr class="dropdown-divider"></li>
                            <li>@Html.ActionLink("My Competencies", "MyCompetencies", "UserCompetency", new { area = "CLIP" }, new { @class = "dropdown-item" })</li>
                            <li>@Html.ActionLink("Log Training Activity", "Index", "ActivityTraining", new { area = "CLIP" }, new { @class = "dropdown-item" })</li>
                        </ul>
                    </li>
                    <li>@Html.ActionLink("Certificate of Fitness", "Index", "CertificateOfFitness", new { area = "CLIP" }, new { @class = "nav-link" })</li>
                </ul>
                }
                <div class="ms-auto">
                    @Html.Partial("_LoginPartial")
                </div>
            </div>
        </div>
    </nav>
    <div class="container body-content">
        @Html.AntiForgeryToken()
        @RenderBody()
        <hr />
        <footer class="py-3">
            <div class="text-center">
                <p class="mb-1">&copy; @DateTime.Now.Year - Inari Amertron Berhad</p>
                <p class="mb-1">CLIP | Competency, Licensing and Important Permit Management System</p>
                <p class="mb-0 text-muted small">Environment, Health and Safety Department</p>
            </div>
        </footer>
    </div>

    @Scripts.Render("~/bundles/jquery")
    @Scripts.Render("~/bundles/bootstrap")
    @RenderSection("scripts", required: false)
    
    <!-- Idle Timeout Script -->
    <script type="text/javascript">
        $(document).ready(function () {
            // Idle timeout settings
            var idleTime = 0;
            var idleInterval;
            var idleTimeout = 30; // Idle timeout in minutes
            var warningTime = 1; // Warning time in minutes before logout
            var warningDisplayed = false;
            var heartbeatInterval;
            
            // Reset the idle timer on user activity
            function resetIdleTime() {
                idleTime = 0;
                if (warningDisplayed) {
                    $('#idleTimeoutWarning').modal('hide');
                    warningDisplayed = false;
                }
            }
            
            // Send a heartbeat to the server to keep the session alive
            function sendHeartbeat() {
                $.ajax({
                    type: "POST",
                    url: '@Url.Action("KeepAlive", "Session", new { area = "CLIP" })',
                    success: function(data) {
                        console.log("Session heartbeat successful");
                    },
                    error: function(error) {
                        console.log("Session heartbeat failed");
                    }
                });
            }
            
            // Start the idle timer
            function startIdleTimer() {
                // Reset the idle timer on various user interactions
                $(document).on('mousemove keypress click scroll', function() {
                    resetIdleTime();
                    
                    // Send a heartbeat to the server when user is active
                    // but limit it to once every 5 minutes to reduce server load
                    if (!heartbeatInterval) {
                        sendHeartbeat();
                        heartbeatInterval = setTimeout(function() {
                            heartbeatInterval = null;
                        }, 300000); // 5 minutes
                    }
                });
                
                // Increment the idle time counter every minute
                idleInterval = setInterval(function() {
                    idleTime += 1;
                    
                    // Show warning when approaching timeout
                    if (idleTime >= (idleTimeout - warningTime) && !warningDisplayed) {
                        warningDisplayed = true;
                        $('#idleTimeoutWarning').modal('show');
                        
                        // Start countdown in the warning modal
                        var countdown = warningTime * 60;
                        var countdownInterval = setInterval(function() {
                            countdown -= 1;
                            var minutes = Math.floor(countdown / 60);
                            var seconds = countdown % 60;
                            $('#countdown').text(minutes + ':' + (seconds < 10 ? '0' : '') + seconds);
                            
                            if (countdown <= 0) {
                                clearInterval(countdownInterval);
                            }
                        }, 1000);
                    }
                    
                    // Log out when idle timeout is reached
                    if (idleTime >= idleTimeout) {
                        clearInterval(idleInterval);
                        document.getElementById('logoutForm').submit();
                    }
                }, 60000); // Check every minute
            }
            
            // Start the idle timer when the page loads
            startIdleTimer();
            
            // Stay active button in the warning modal
            $('#stayActiveBtn').on('click', function() {
                resetIdleTime();
                sendHeartbeat(); // Explicitly send a heartbeat when user clicks "Stay Active"
            });
        });
    </script>
    
    <!-- Idle Timeout Warning Modal -->
    <div class="modal fade" id="idleTimeoutWarning" data-bs-backdrop="static" tabindex="-1" aria-labelledby="idleTimeoutWarningLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header bg-warning">
                    <h5 class="modal-title" id="idleTimeoutWarningLabel">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Session Timeout Warning
                    </h5>
                </div>
                <div class="modal-body text-center">
                    <p>Your session is about to expire due to inactivity.</p>
                    <p>You will be logged out in <strong><span id="countdown">2:00</span></strong> minutes.</p>
                    <p>Do you want to stay signed in?</p>
                </div>
                <div class="modal-footer justify-content-center">
                    <button type="button" id="stayActiveBtn" class="btn btn-primary">
                        <i class="fas fa-check me-1"></i>
                        Yes, Keep Me Signed In
                    </button>
                    <button type="button" class="btn btn-secondary" onclick="document.getElementById('logoutForm').submit();">
                        <i class="fas fa-sign-out-alt me-1"></i>
                        Log Out Now
                    </button>
                </div>
            </div>
        </div>
    </div>
</body>
</html>
