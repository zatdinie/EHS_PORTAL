@model IEnumerable<EHS_PORTAL.Areas.CLIP.Models.Monitoring>

@{
    ViewBag.Title = "Monitoring Types";
    var recordCount = Model.Count();

    // Calculate frequencies for visualization
    var monthlyCount = Model.Count(i => i.MonitoringFreq <= 3);
    var quarterlyCount = Model.Count(i => i.MonitoringFreq > 3 && i.MonitoringFreq <= 6);
    var yearlyCount = Model.Count(i => i.MonitoringFreq > 6 && i.MonitoringFreq <= 12);
    var multiYearCount = Model.Count(i => i.MonitoringFreq > 12);

    // Calculate percentages
    var monthlyPercent = recordCount > 0 ? (int)Math.Round((double)monthlyCount / recordCount * 100) : 0;
    var quarterlyPercent = recordCount > 0 ? (int)Math.Round((double)quarterlyCount / recordCount * 100) : 0;
    var yearlyPercent = recordCount > 0 ? (int)Math.Round((double)yearlyCount / recordCount * 100) : 0;
    var multiYearPercent = recordCount > 0 ? (int)Math.Round((double)multiYearCount / recordCount * 100) : 0;

    // Get distinct categories
    var categories = Model.Select(m => m.MonitoringCategory).Distinct().ToList();
}

<br></br>
<h1>Monitoring Types</h1>

<div class="card mb-4">
    <div class="card-body">
        @using (Html.BeginForm("Index", "Monitoring", FormMethod.Get, new { @class = "row g-3" }))
        {
            <div class="col-md-10">
                <label class="form-label"><i class="bi bi-search"></i> Search by Monitoring Name or Category</label>
                <div class="input-group">
                    @Html.TextBox("searchString", ViewBag.CurrentSearch as string, new { @class = "form-control",
                    placeholder = "Enter monitoring name or category..." })
                    <button type="submit" class="btn btn-outline-primary">
                        <i class="bi bi-search"></i> Search
                    </button>
                </div>
                <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort" />
                <input type="hidden" name="categoryFilter" value="@ViewBag.CurrentCategoryFilter" />
            </div>
            <div class="col-md-2 d-flex align-items-end">
                @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string) || ViewBag.CurrentCategoryFilter != null)
                {
                    <a href="@Url.Action("Index", "Monitoring")" class="btn btn-outline-secondary">
                        <i class="bi bi-x-circle"></i> Clear Filters
                    </a>
                }
            </div>
        }

        <div class="mt-3">
            <div class="d-flex flex-wrap gap-2">
                @foreach (var category in categories)
                {
                    <a href="@Url.Action("Index", "Monitoring", new { categoryFilter = category, searchString = ViewBag.CurrentSearch, sortOrder = ViewBag.CurrentSort })"
                       class="btn @(ViewBag.CurrentCategoryFilter != null && ViewBag.CurrentCategoryFilter.ToString() == category ? "btn-primary" : "btn-outline-primary")">
                        @category
                    </a>
                }
            </div>
        </div>
    </div>
</div>

<div class="d-flex justify-content-between align-items-center mb-3">
    @if (User.IsInRole("Admin"))
    {
        <a href="@Url.Action("Create")" class="btn btn-primary">
            <i class="bi bi-plus-circle"></i> Add New Type
        </a>
    }
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="table-responsive">
    <table class="table table-hover" id="monitoringTable">
        <thead class="bg-light">
            <tr>
                <th>
                    <a href="@Url.Action("Index", "Monitoring", new { sortOrder = ViewBag.NameSortParam, searchString = ViewBag.CurrentSearch, categoryFilter = ViewBag.CurrentCategoryFilter })"
                       class="text-dark text-decoration-none">
                        @Html.DisplayNameFor(model => model.MonitoringName)
                        @if (ViewBag.CurrentSort == "name_asc")
                        {
                            <i class="bi bi-sort-alpha-down"></i>
                        }
                        else if (ViewBag.CurrentSort == "name_desc")
                        {
                            <i class="bi bi-sort-alpha-up"></i>
                        }
                        else
                        {
                            <i class="bi bi-arrow-down-up text-muted"></i>
                        }
                    </a>
                </th>
                <th>
                    <a href="@Url.Action("Index", "Monitoring", new { sortOrder = ViewBag.CategorySortParam, searchString = ViewBag.CurrentSearch, categoryFilter = ViewBag.CurrentCategoryFilter })"
                        class="text-dark text-decoration-none">
                        @Html.DisplayNameFor(model => model.MonitoringCategory)
                        @if (ViewBag.CurrentSort == "category_asc")
                        {
                            <i class="bi bi-sort-alpha-down"></i>
                        }
                        else if (ViewBag.CurrentSort == "category_desc")
                        {
                            <i class="bi bi-sort-alpha-up"></i>
                        }
                        else
                        {
                            <i class="bi bi-arrow-down-up text-muted"></i>
                        }
                    </a>
                </th>
                <th>
                    <a href="@Url.Action("Index", "Monitoring", new { sortOrder = ViewBag.FreqSortParam, searchString = ViewBag.CurrentSearch, categoryFilter = ViewBag.CurrentCategoryFilter })"
                       class="text-dark text-decoration-none">
                        @Html.DisplayNameFor(model => model.MonitoringFreq)
                        @if (ViewBag.CurrentSort == "freq_asc")
                        {
                            <i class="bi bi-sort-numeric-down"></i>
                        }
                        else if (ViewBag.CurrentSort == "freq_desc")
                        {
                            <i class="bi bi-sort-numeric-up"></i>
                        }
                        else
                        {
                            <i class="bi bi-arrow-down-up text-muted"></i>
                        }
                    </a>
                </th>
                <th class="text-center">Actions</th>
            </tr>
        </thead>
        <tbody>
            @if (Model.Count() == 0)
            {
                <tr>
                    <td colspan="4" class="text-center py-4">
                        <i class="bi bi-info-circle text-info fs-4 d-block mb-2"></i>
                        @if (!string.IsNullOrEmpty(ViewBag.CurrentSearch as string) || ViewBag.CurrentCategoryFilter != null)
                        {
                            <p class="mb-1">No monitoring types found matching your filters.</p>
                            <a href="@Url.Action("Index", "Monitoring")" class="btn btn-outline-primary btn-sm mt-2">
                                <i class="bi bi-arrow-clockwise"></i> Show All Types
                            </a>
                        }
                        else
                        {
                            <p>No monitoring types have been added yet.</p>
                            if (User.IsInRole("Admin"))
                            {
                                <a href="@Url.Action("Create")" class="btn btn-primary btn-sm mt-2">
                                    <i class="bi bi-plus-circle"></i> Add New Type
                                </a>
                            }
                        }
                    </td>
                </tr>
            }
            else
            {
                foreach (var item in Model)
                {
                    <tr>
                        <td>@Html.DisplayFor(modelItem => item.MonitoringName)</td>
                        <td>@Html.DisplayFor(modelItem => item.MonitoringCategory)</td>
                        <td>
                            @{
                                string frequencyText = "Unknown";
                                int freq = item.MonitoringFreq;

                                if (freq == 1) { frequencyText = "Monthly"; }
                                else if (freq == 2) { frequencyText = "Bi-Monthly"; }
                                else if (freq == 3) { frequencyText = "Quarterly"; }
                                else if (freq == 4) { frequencyText = "4 Months"; }
                                else if (freq == 6) { frequencyText = "Half-Yearly"; }
                                else if (freq == 8) { frequencyText = "8 Months"; }
                                else if (freq == 12) { frequencyText = "Yearly"; }
                                else if (freq == 15) { frequencyText = "15 Months"; }
                                else if (freq == 18) { frequencyText = "18 Months"; }
                                else if (freq == 24) { frequencyText = "Every 2 Years"; }
                                else if (freq == 36) { frequencyText = "Every 3 Years"; }
                                else if (freq == 48) { frequencyText = "Every 4 Years"; }
                                else if (freq == 60) { frequencyText = "Every 5 Years"; }
                                else { frequencyText = $"Every {freq} months"; }
                            }
                            @frequencyText
                        </td>
                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <a href="@Url.Action("Details", new { id = item.MonitoringID })"
                                   class="btn btn-info btn-sm" data-bs-toggle="tooltip" title="View Details">
                                    <i class="bi bi-info-circle"></i>
                                </a>
                                @if (User.IsInRole("Admin"))
                                {
                                    <a href="@Url.Action("Edit", new { id = item.MonitoringID })"
                                       class="btn btn-warning btn-sm" data-bs-toggle="tooltip" title="Edit">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>
                                    <a href="@Url.Action("Delete", new { id = item.MonitoringID })"
                                       class="btn btn-danger btn-sm" data-bs-toggle="tooltip" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                }
                            </div>
                        </td>
                    </tr>
                }
            }
        </tbody>
    </table>
</div>

@section Scripts {
    <script>
        $(function () {
            // Enable tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();

            // Add data table functionalities
            if ($.fn.DataTable) {
                $('#monitoringTable').DataTable({
                    "paging": true,
                    "ordering": true,
                    "info": true,
                    "searching": true,
                    "pageLength": 10,
                    "language": {
                        "lengthMenu": "Show _MENU_ records per page",
                        "zeroRecords": "No matching records found",
                        "info": "Showing _START_ to _END_ of _TOTAL_ records",
                        "infoEmpty": "Showing 0 to 0 of 0 records",
                        "infoFiltered": "(filtered from _MAX_ total records)"
                    }
                });
            }
        });
    </script>
}