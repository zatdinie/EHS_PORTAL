@model EHS_PORTAL.Areas.CLIP.Models.RegisterViewModel
@{
    ViewBag.Title = "Register";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-secondary text-white">
                    <h4 class="card-title mb-0">Create a new account</h4>
                </div>
                <div class="card-body">
                    @using (Html.BeginForm("Register", "Account", FormMethod.Post, new { @class = "needs-validation", role = "form", novalidate = "novalidate" }))
                    {
                        @Html.AntiForgeryToken()
                        
                        @Html.ValidationSummary("", new { @class = "text-danger mb-3" })
                        
                        <div class="mb-3">
                            <label for="Email" class="form-label"><strong>@Html.LabelFor(m => m.Email)</strong></label>
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.Email, new { @class = "form-control"})
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter user's email address">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="UserName" class="form-label"><strong>@Html.LabelFor(m => m.UserName)</strong></label>
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.UserName, new { @class = "form-control"})
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Add Username">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="EmpID" class="form-label"><strong>@Html.LabelFor(m => m.EmpID)</strong></label>
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.EmpID, new { @class = "form-control"})
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter user's Employee ID">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(m => m.EmpID, "", new { @class = "text-danger" })
                        </div>
                        
                        <div class="mb-3">
                            <label for="DOE_CPD" class="form-label"><strong>@Html.LabelFor(m => m.DOE_CPD)</strong></label>
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.DOE_CPD, new { @class = "form-control", type = "number"})
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter user's current DOE CPD Points">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(m => m.DOE_CPD, "", new { @class = "text-danger" })
                        </div>
                        
                        <div class="mb-3">
                            <label for="Dosh_CEP" class="form-label"><strong>@Html.LabelFor(m => m.Dosh_CEP)</strong></label>
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.Dosh_CEP, new { @class = "form-control", type = "number"})
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter user's current DOSH CEP Points">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(m => m.Dosh_CEP, "", new { @class = "text-danger" })
                        </div>
                        
                        <div class="mb-3">
                            <label for="Atom_CEP" class="form-label"><strong>@Html.LabelFor(m => m.Atom_CEP)</strong></label>
                            <div class="input-group">
                                @Html.TextBoxFor(m => m.Atom_CEP, new { @class = "form-control", type = "number"})
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Enter user's current ATOM CEP Points">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(m => m.Atom_CEP, "", new { @class = "text-danger" })
                        </div>
                        
                        <div class="mb-3">
                            <label for="Password" class="form-label"><strong>@Html.LabelFor(m => m.Password)</strong></label>
                            <div class="input-group">
                                @Html.PasswordFor(m => m.Password, new { @class = "form-control"})
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Create a secure password">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="ConfirmPassword" class="form-label"><strong>@Html.LabelFor(m => m.ConfirmPassword)</strong></label>
                            <div class="input-group">
                                @Html.PasswordFor(m => m.ConfirmPassword, new { @class = "form-control"})
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Confirm user's password">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                        </div>
                        
                        <div class="mb-3">
                            <label for="Role" class="form-label"><strong>@Html.LabelFor(m => m.Role)</strong></label>
                            <div class="input-group">
                                @Html.DropDownListFor(m => m.Role, Model.RolesList, "-- Select Role --", new { @class = "form-select" })
                                <span class="input-group-text" data-bs-toggle="tooltip" title="Select role">
                                    <i class="bi bi-info-circle"></i>
                                </span>
                            </div>
                            @Html.ValidationMessageFor(m => m.Role, "", new { @class = "text-danger" })
                        </div>
                        
                        <div class="mb-4">
                            <label for="SelectedPlantIds" class="form-label"><strong>@Html.LabelFor(m => m.SelectedPlantIds)</strong></label>
                            <div class="card">
                                <div class="card-body">
                                    <div class="row">
                                        @foreach (var plant in Model.PlantsList)
                                        {
                                            <div class="col-md-6 mb-2">
                                                <div class="form-check">
                                                    <input type="checkbox" 
                                                            name="SelectedPlantIds" 
                                                            value="@plant.Value" 
                                                            id="plant_@plant.Value" 
                                                            class="form-check-input" />
                                                    <label class="form-check-label" for="plant_@plant.Value">@plant.Text</label>
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                            <small class="text-muted">Select all plants that apply</small>
                        </div>
                        
                        <div class="mt-4 d-flex justify-content-between">
                            <a href="@Url.Action("Users", "Manage")" class="btn btn-outline-secondary">
                                <i class="fas fa-arrow-left me-2"></i>Back to User Management
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fas fa-user-plus me-2"></i>Create account
                            </button>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @Scripts.Render("~/bundles/jqueryval")
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    
    <script>
        $(document).ready(function () {
            // Initialize tooltips
            $('[data-bs-toggle="tooltip"]').tooltip();
            
            // Bootstrap form validation
            (function () {
                'use strict'
                var forms = document.querySelectorAll('.needs-validation')
                Array.prototype.slice.call(forms)
                    .forEach(function (form) {
                        form.addEventListener('submit', function (event) {
                            if (!form.checkValidity()) {
                                event.preventDefault()
                                event.stopPropagation()
                            }
                            form.classList.add('was-validated')
                        }, false)
                    })
            })()
        });
    </script>
}
